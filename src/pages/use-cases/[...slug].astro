---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('use-cases');
  return pages.map((page) => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);
---

<Base
  title={`${page.data.title} — Crontinel`}
  description={page.data.description ?? page.data.title}
>
  <Nav />

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
    <a href="/use-cases" class="text-sm text-gray-500 hover:text-gray-300 mb-8 inline-block">← All use cases</a>
    <h1 class="text-3xl font-bold text-white mb-8">{page.data.title}</h1>
    <article class="prose prose-invert prose-gray text-sm leading-relaxed max-w-none
      prose-headings:text-white prose-headings:font-semibold
      prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-base prose-h3:mt-6 prose-h3:mb-2
      prose-p:text-gray-400 prose-p:mb-4
      prose-li:text-gray-400
      prose-strong:text-white
      prose-code:text-green-400 prose-code:bg-green-500/10 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-normal
      prose-pre:bg-gray-950 prose-pre:border prose-pre:border-gray-800 prose-pre:rounded-xl
      prose-table:text-sm prose-th:text-gray-400 prose-th:font-medium prose-td:text-gray-300
      prose-a:text-green-400 prose-a:no-underline hover:prose-a:text-green-300">
      <Content />
    </article>

    <div class="mt-16 bg-gray-900 border border-green-500/20 rounded-xl p-8 text-center">
      <h2 class="text-xl font-bold text-white mb-2">Start monitoring in minutes</h2>
      <p class="text-gray-400 mb-6">
        Free for one app. No account needed to install and test locally.
      </p>
      <div class="relative max-w-sm mx-auto mb-6">
        <div class="bg-gray-950 rounded-lg p-4 pr-14 font-mono text-sm text-green-400 text-left">
          <div>composer require crontinel/laravel</div>
          <div>php artisan crontinel:install</div>
        </div>
        <button onclick="navigator.clipboard.writeText('composer require crontinel/laravel\nphp artisan crontinel:install'); this.textContent='Copied!'; setTimeout(()=>this.textContent='Copy',1500)" class="absolute top-2 right-2 text-xs text-gray-500 hover:text-gray-300 bg-gray-800 hover:bg-gray-700 px-2 py-1 rounded transition-colors">Copy</button>
      </div>
      <a
        href="/#waitlist"
        class="inline-block bg-green-500 hover:bg-green-400 text-black font-semibold px-6 py-2.5 rounded transition-colors"
      >
        Get early access
      </a>
    </div>
  </main>

  <Footer />
</Base>
