---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const useCases = (await getCollection('use-cases'))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

function getCategory(slug) {
  if (slug.startsWith('laravel-cron') || slug.startsWith('cron-') || slug.includes('schedule')) return 'Cron and Scheduler';
  if (slug.startsWith('laravel-horizon') || slug.startsWith('monitor-horizon') || slug.includes('horizon')) return 'Horizon and Workers';
  if (slug.startsWith('laravel-queue') || slug.startsWith('monitor-queue') || slug.includes('queue')) return 'Queue Monitoring';
  if (slug.startsWith('monitor-cache') || slug.startsWith('monitor-config') || slug.startsWith('monitor-route') || slug.startsWith('monitor-event') || slug.startsWith('monitor-optimize') || slug.startsWith('monitor-view') || slug.startsWith('monitor-notifications-prune') || slug.startsWith('monitor-model-prune') || slug.startsWith('monitor-php-artisan')) return 'Cache and Optimize';
  if (slug.startsWith('monitor-migrate') || slug.includes('db-backup')) return 'Database and Migrations';
  if (slug.startsWith('monitor-backup') || slug.includes('storage')) return 'Backup and Storage';
  if (slug.startsWith('monitor-scout') || slug.startsWith('monitor-telescope')) return 'Scout and Telescope';
  if (slug.includes('alert') || slug.includes('incident') || slug.includes('webhook')) return 'Alerting and Incident Response';
  if (slug.includes('status-page') || slug.includes('status')) return 'Status Pages';
  if (slug.includes('multi-tenant') || slug.includes('saas')) return 'Multi-Tenant and Teams';
  if (slug.includes('deploy') || slug.includes('hook')) return 'Deploy and CI/CD';
  if (slug.includes('pulse')) return 'Pulse';
  if (slug.startsWith('laravel-status')) return 'Status Pages';
  if (slug.startsWith('failed-job') || slug.includes('failed')) return 'Queue Monitoring';
  return 'Other';
}

const grouped = {};
for (const uc of useCases) {
  const cat = getCategory(uc.id);
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push({ slug: uc.id, title: uc.data.title, desc: uc.data.description ?? '' });
}
const groupNames = Object.keys(grouped);
---

<script type="application/ld+json" slot="head">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://crontinel.com" },
    { "@type": "ListItem", "position": 2, "name": "Use Cases", "item": "https://crontinel.com/use-cases/" }
  ]
}
</script>

<Base
  title="Use Cases - Crontinel"
  description="Crontinel for SaaS billing jobs, Horizon-heavy apps, scheduled reports, and multi-tenant Laravel platforms."
>
  <Nav />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-16" id="main-content">

    <div class="text-center mb-14">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Built for production Laravel apps</h1>
      <p class="text-gray-400 max-w-xl mx-auto">
        Crontinel is most valuable when your background jobs are load-bearing: billing, data sync, reporting, communication. Here are all {useCases.length} use cases.
      </p>
    </div>

    {groupNames.map((cat) => (
      <section class="mb-12">
        <h2 class="text-lg font-semibold text-white mb-3 pb-2 border-b border-gray-800">{cat}</h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {grouped[cat].map((uc) => (
            <a href={`/use-cases/${uc.slug}/`} class="block bg-gray-900 border border-gray-800 rounded-lg p-4 transition-colors hover:border-green-500/40 hover:bg-gray-850">
              <h3 class="text-sm font-medium text-white mb-1 leading-snug">{uc.title}</h3>
              {uc.desc && <p class="text-xs text-gray-400 line-clamp-2">{uc.desc}</p>}
            </a>
          ))}
        </div>
      </section>
    ))}

    <div class="bg-gray-900 border border-green-500/20 rounded-xl p-8 text-center">
      <h2 class="text-xl font-bold text-white mb-2">Start in two commands</h2>
      <p class="text-gray-400 mb-6">No account needed. Crontinel works locally and in production from day one.</p>
      <div class="relative max-w-sm mx-auto mb-6">
        <div class="bg-gray-950 rounded-lg p-4 pr-14 font-mono text-sm text-green-400 text-left">
          <div>composer require crontinel/laravel</div>
          <div>php artisan crontinel:install</div>
        </div>
        <button role="button" aria-label="Copy to clipboard" onclick="navigator.clipboard.writeText('composer require crontinel/laravel\nphp artisan crontinel:install'); this.textContent='Copied!'; setTimeout(()=>this.textContent='Copy',1500)" class="absolute top-2 right-2 text-xs text-gray-400 hover:text-gray-300 bg-gray-800 hover:bg-gray-700 px-2 py-1 rounded transition-colors">Copy</button>
      </div>
      <a
        href="https://app.crontinel.com/register"
        class="inline-block bg-green-500 hover:bg-green-400 text-black font-semibold px-6 py-2.5 rounded transition-colors"
      >
        Get early access
      </a>
    </div>

  </main>

  <Footer />
</Base>
