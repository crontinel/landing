---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Page Not Found  |  Crontinel"
  description="The page you're looking for doesn't exist."
>
  <Nav />

  <main class="max-w-2xl mx-auto px-4 sm:px-6 py-24 text-center">
    <p class="text-green-500 text-sm font-medium mb-4 tracking-wide uppercase">404</p>
    <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">
      Nothing here.
    </h1>
    <p class="text-gray-400 text-lg mb-10 max-w-md mx-auto">
      This page doesn't exist. Maybe the cron job that was supposed to create it silently failed.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-400 text-black font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
      >
        Go home
      </a>
      <a
        href="https://docs.crontinel.com"
        class="inline-flex items-center gap-2 border border-gray-700 hover:border-gray-500 text-gray-300 font-medium px-6 py-3 rounded-lg transition-colors text-sm"
      >
        Read the docs
      </a>
    </div>
  </main>

  <Footer />
</Base>
