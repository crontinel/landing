---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const integrations = [
  {
    name: 'Slack',
    status: 'available',
    description: 'Post alerts to any Slack channel when Horizon pauses, a queue backs up, or a cron job fails.',
    config: 'CRONTINEL_SLACK_WEBHOOK',
    icon: '#',
  },
  {
    name: 'Email',
    status: 'available',
    description: 'Send alert emails via Laravel\'s built-in mail system. Works with any SMTP provider, Mailgun, or Resend.',
    config: 'CRONTINEL_ALERT_EMAIL',
    icon: '✉',
  },
  {
    name: 'Webhook',
    status: 'coming-soon',
    description: 'Fire a POST to any URL when an alert triggers. Route to PagerDuty, Opsgenie, or your own handler.',
    config: null,
    icon: '⚡',
  },
  {
    name: 'PagerDuty',
    status: 'coming-soon',
    description: 'Create incidents in PagerDuty directly from Crontinel alerts with full event payload.',
    config: null,
    icon: '🔔',
  },
];
---

<Base
  title="Integrations — Crontinel"
  description="Connect Crontinel alerts to Slack, email, webhooks, and PagerDuty. Get notified the moment something breaks in your Laravel app."
>
  <Nav />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-16">

    <div class="text-center mb-14">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Integrations</h1>
      <p class="text-gray-400 max-w-xl mx-auto">
        Crontinel fires alerts through your existing channels. Configure once in your <code class="text-green-400 bg-green-500/10 px-1.5 py-0.5 rounded text-sm">.env</code> — no dashboard needed.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-4 mb-16">
      {integrations.map((i) => (
        <div class={`bg-gray-900 border rounded-xl p-6 ${i.status === 'coming-soon' ? 'border-gray-800 opacity-60' : 'border-gray-800'}`}>
          <div class="flex items-start justify-between mb-3">
            <h2 class="text-lg font-semibold text-white">{i.name}</h2>
            {i.status === 'coming-soon'
              ? <span class="text-xs text-gray-500 bg-gray-800 px-2 py-0.5 rounded-full">Soon</span>
              : <span class="text-xs text-green-400 bg-green-500/10 border border-green-500/20 px-2 py-0.5 rounded-full">Available</span>
            }
          </div>
          <p class="text-sm text-gray-400 mb-4">{i.description}</p>
          {i.config && (
            <div class="font-mono text-xs text-green-400 bg-gray-950 rounded px-3 py-2">
              {i.config}=your-value
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-xl p-8">
      <h2 class="text-lg font-bold text-white mb-4">Alert config reference</h2>
      <div class="space-y-3 font-mono text-sm">
        <div class="flex gap-4 text-gray-400">
          <code class="text-green-400 min-w-[220px]">CRONTINEL_ALERT_CHANNEL</code>
          <span>slack | mail | null (default: null)</span>
        </div>
        <div class="flex gap-4 text-gray-400">
          <code class="text-green-400 min-w-[220px]">CRONTINEL_SLACK_WEBHOOK</code>
          <span>Your Slack incoming webhook URL</span>
        </div>
        <div class="flex gap-4 text-gray-400">
          <code class="text-green-400 min-w-[220px]">CRONTINEL_ALERT_EMAIL</code>
          <span>Email address to notify</span>
        </div>
      </div>
    </div>

  </main>

  <Footer />
</Base>
