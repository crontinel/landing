---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base
  title={`${post.data.title} — Crontinel Blog`}
  description={post.data.description ?? post.data.title}
>
  <Nav />

  <main class="max-w-2xl mx-auto px-4 sm:px-6 py-16">
    <a href="/blog" class="text-sm text-gray-500 hover:text-gray-300 mb-8 inline-block">← Back to blog</a>
    <time class="block text-xs text-gray-500 font-mono mb-2">{post.data.date.toISOString().slice(0, 10)}</time>
    <h1 class="text-3xl font-bold text-white mb-8">{post.data.title}</h1>
    <article class="prose prose-invert prose-gray text-sm leading-relaxed max-w-none">
      <Content />
    </article>
  </main>

  <Footer />
</Base>
