---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base
  title="Blog — Crontinel"
  description="Laravel monitoring tips, Horizon deep dives, and cron job best practices."
>
  <Nav />

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
    <h1 class="text-3xl font-bold text-white mb-2">Blog</h1>
    <p class="text-gray-400 mb-12">Laravel monitoring, Horizon deep dives, and cron best practices.</p>

    {posts.length === 0 ? (
      <p class="text-gray-500">Posts coming soon.</p>
    ) : (
      <div class="space-y-8">
        {posts.map((post) => (
          <article class="border-b border-gray-800 pb-8">
            <time class="text-xs text-gray-500 font-mono">{post.data.date.toISOString().slice(0, 10)}</time>
            <h2 class="text-xl font-semibold text-white mt-1 mb-2">
              <a href={`/blog/${post.id}`} class="hover:text-green-400 transition-colors">
                {post.data.title}
              </a>
            </h2>
            {post.data.description && (
              <p class="text-gray-400 text-sm mb-3">{post.data.description}</p>
            )}
            <a href={`/blog/${post.id}`} class="text-sm text-green-400 hover:text-green-300">
              Read more →
            </a>
          </article>
        ))}
      </div>
    )}
  </main>

  <Footer />
</Base>
