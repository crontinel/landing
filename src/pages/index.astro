<style>
  /* ============================================
     DESIGN TOKENS
     ============================================ */
  :root {
    --accent: #22c55e;
    --accent-dim: rgba(34,197,94,0.15);
    --bg: #09090b;
    --bg-2: #0f0f12;
    --text: #f8fafc;
    --text-2: #94a3b8;
    --text-3: #475569;
    --border: rgba(148,163,184,0.1);
    --danger: #ef4444;
    --warn: #f59e0b;
    --radius: 12px;
    --font-mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    --font-sans: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
  }

  /* ============================================
     RESET / BASE
     ============================================ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    line-height: 1.6;
    overflow-x: hidden;
  }

  .container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .mono { font-family: var(--font-mono); }
  .accent { color: var(--accent); }
  .ok-green { color: var(--accent); }
  .danger { color: var(--danger); }
  .warn { color: var(--warn); }
  .text-2 { color: var(--text-2); }
  .text-3 { color: var(--text-3); }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; }

  /* ============================================
     DOTS
     ============================================ */
  .dot {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 50%;
    vertical-align: middle;
    margin-right: 6px;
    flex-shrink: 0;
  }
  .dot-ok { background: var(--accent); }
  .dot-fail { background: var(--danger); }
  .dot-warn { background: var(--warn); }
  .pulse {
    animation: pulse-anim 2s ease-in-out infinite;
  }
  @keyframes pulse-anim {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(34,197,94,0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(34,197,94,0); }
  }

  /* ============================================
     BUTTONS
     ============================================ */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.65rem 1.4rem;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .btn-primary {
    background: var(--accent);
    color: #000;
  }
  .btn-primary:hover {
    background: #16a34a;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(34,197,94,0.3);
  }
  .btn-ghost {
    background: transparent;
    color: var(--text-2);
    border: 1px solid rgba(148,163,184,0.2);
  }
  .btn-ghost:hover {
    border-color: rgba(148,163,184,0.4);
    color: var(--text);
  }
  .btn-sm {
    font-size: 0.8rem;
    padding: 0.4rem 0.9rem;
  }
  .btn-lg {
    font-size: 1rem;
    padding: 0.8rem 2rem;
  }

  /* ============================================
     EYEBROW
     ============================================ */
  .eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 1rem;
    font-family: var(--font-mono);
  }

  /* ============================================
     SECTION
     ============================================ */
  .section {
    padding: 6rem 0;
  }
  .section-head {
    text-align: center;
    max-width: 42rem;
    margin: 0 auto 3.5rem;
  }
  .section-head h2 {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .section-head p {
    color: var(--text-2);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 36rem;
    margin: 0 auto;
  }

  /* ============================================
     CARD
     ============================================ */
  .card {
    background: var(--bg-2);
    border: 1px solid rgba(148,163,184,0.08);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .card:hover {
    border-color: rgba(148,163,184,0.18);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .card p {
    color: var(--text-2);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* ============================================
     NAV
     ============================================ */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background 0.3s, backdrop-filter 0.3s, border-color 0.3s;
    border-bottom: 1px solid transparent;
  }
  .nav.scrolled {
    background: rgba(9,9,11,0.82);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border-bottom-color: var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1rem;
    color: var(--text);
  }
  .nav-links {
    display: flex;
    gap: 1.8rem;
  }
  .nav-links a {
    font-size: 0.85rem;
    color: var(--text-2);
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--text-2);
    cursor: pointer;
    padding: 0.25rem;
  }
  .nav-mobile {
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1.5rem 1.5rem;
    border-top: 1px solid var(--border);
    background: var(--bg);
  }
  .nav-mobile a {
    display: block;
    padding: 0.6rem 0;
    color: var(--text-2);
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .nav-mobile a:hover { color: var(--text); }
  .nav-mobile-ctas {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-right .btn { display: none; }
    .nav-toggle { display: block; }
    .nav-mobile.open {
      display: flex;
    }
  }

  /* ============================================
     HERO
     ============================================ */
  .hero {
    position: relative;
    padding: 7rem 0 4rem;
    overflow: hidden;
    min-height: 80vh;
    display: flex;
    align-items: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(148,163,184,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148,163,184,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .hero-glow {
    position: absolute;
    top: -20%;
    left: 30%;
    width: 60%;
    height: 80%;
    background: radial-gradient(ellipse at center, rgba(99,102,241,0.15) 0%, rgba(139,92,246,0.08) 40%, transparent 70%);
    filter: blur(60px);
    animation: heroGlowAnim 8s ease-in-out infinite;
  }
  @keyframes heroGlowAnim {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.08); }
  }
  .hero-scanline {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .hero-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-2);
    padding: 0.35rem 0.8rem;
    background: rgba(34,197,94,0.08);
    border: 1px solid rgba(34,197,94,0.15);
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }
  .hero h1 {
    font-size: clamp(2.5rem, 5.5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }
  .cursor {
    color: var(--accent);
    animation: blink 1s steps(1) infinite;
  }
  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }
  .hero-sub {
    color: var(--text-2);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 30rem;
  }
  .hero-sub em { color: var(--text); font-style: normal; font-weight: 600; }
  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .hero-trust {
    font-size: 0.72rem;
    color: var(--text-3);
    letter-spacing: 0.02em;
  }

  /* Monitor widget */
  .monitor {
    background: rgba(15,15,18,0.9);
    border: 1px solid rgba(148,163,184,0.1);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .monitor-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 1rem;
    font-size: 0.7rem;
    color: var(--text-3);
    border-bottom: 1px solid var(--border);
    background: rgba(0,0,0,0.3);
  }
  .monitor-stats {
    color: var(--text-2);
  }
  .monitor-graph {
    padding: 1rem;
    height: 140px;
  }
  .monitor-graph svg {
    width: 100%;
    height: 100%;
  }
  .monitor-feed {
    padding: 0.5rem 1rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    max-height: 120px;
    overflow: hidden;
  }
  .feed-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0;
    color: var(--text-2);
    animation: feedSlide 0.3s ease-out;
  }
  @keyframes feedSlide {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .feed-row .feed-time { color: var(--text-3); margin-left: auto; }

  .hero-captions {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    font-size: 0.72rem;
    color: var(--text-3);
  }
  .hero-captions span {
    display: flex;
    align-items: center;
  }

  @media (max-width: 900px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .hero { min-height: auto; padding: 5rem 0 3rem; }
    .hero-captions { flex-wrap: wrap; gap: 0.75rem; }
  }

  /* ============================================
     METRICS
     ============================================ */
  .section-metrics {
    padding: 3rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  .metric {
    text-align: center;
  }
  .metric-n {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--text);
    font-family: var(--font-mono);
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .metric-n .unit {
    font-size: 0.5em;
    color: var(--text-2);
    font-weight: 500;
  }
  .metric-l {
    font-size: 0.85rem;
    color: var(--text-3);
    max-width: 14rem;
    margin: 0 auto;
  }

  @media (max-width: 640px) {
    .metrics { grid-template-columns: repeat(2, 1fr); }
  }

  /* ============================================
     PROBLEM
     ============================================ */
  .section-head-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    margin-bottom: 3rem;
  }
  .section-head-copy .eyebrow { margin-bottom: 0.75rem; }
  .section-head-copy h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.5rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .section-head-copy p {
    color: var(--text-2);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .gap-wall {
    display: flex;
    gap: 0;
    background: var(--bg-2);
    border: 1px solid rgba(148,163,184,0.08);
    border-radius: var(--radius);
    overflow: hidden;
    font-size: 0.8rem;
  }
  .gap-col {
    flex: 1;
    padding: 1rem;
  }
  .gap-col-truth { background: rgba(34,197,94,0.03); }
  .gap-label {
    font-size: 0.7rem;
    color: var(--text-3);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .gap-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0;
    font-size: 0.75rem;
  }
  .gap-val {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
  }
  .gap-divider {
    display: flex;
    align-items: center;
    padding: 0 0.75rem;
    font-size: 0.7rem;
    color: var(--text-3);
    font-family: var(--font-mono);
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    background: rgba(0,0,0,0.3);
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .problem .pico {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--text-3);
    margin-bottom: 0.75rem;
  }
  .problem h3 { margin-bottom: 0.5rem; }
  .problem pre {
    margin-top: 1rem;
    padding: 0.75rem;
    background: rgba(0,0,0,0.4);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    font-size: 0.72rem;
    color: var(--text-2);
    overflow-x: auto;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .section-head-split { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .problem-grid { grid-template-columns: 1fr; }
  }

  /* ============================================
     BENTO GRID
     ============================================ */
  .bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  .b { padding: 1.5rem; }
  .b-lg { grid-column: span 2; }
  .b-md { grid-column: span 2; }
  .b-sm { grid-column: span 1; }
  .b-wide { grid-column: span 4; }

  @media (max-width: 768px) {
    .bento { grid-template-columns: 1fr; }
    .b-lg, .b-md, .b-sm, .b-wide { grid-column: span 1; }
  }

  /* Worker grid viz */
  .horizon-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
  .worker-cell {
    background: rgba(0,0,0,0.4);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-2);
    transition: border-color 0.3s, background 0.3s;
  }
  .worker-cell.busy {
    border-color: rgba(34,197,94,0.2);
    background: rgba(34,197,94,0.04);
  }
  .worker-cell.paused {
    border-color: rgba(245,158,11,0.2);
    background: rgba(245,158,11,0.04);
  }
  .worker-cell.idle {
    border-color: var(--border);
  }

  /* Heartbeat pulse viz */
  .viz-ping {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
    padding: 1rem 0;
  }
  .wave {
    position: relative;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .wave::before {
    content: '';
    width: 12px; height: 12px;
    background: var(--accent);
    border-radius: 50%;
    position: relative;
    z-index: 1;
  }
  .wave-ring {
    position: absolute;
    inset: 0;
    border: 1px solid var(--accent);
    border-radius: 50%;
    opacity: 0;
    animation: waveExpand 2s ease-out infinite;
  }
  .wave-ring-2 { animation-delay: 0.5s; }
  .wave-ring-3 { animation-delay: 1s; }
  @keyframes waveExpand {
    0% { transform: scale(0.3); opacity: 0.6; }
    100% { transform: scale(1); opacity: 0; }
  }

  /* Alert channels viz */
  .viz-channels {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .channel-pill {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid rgba(148,163,184,0.15);
    border-radius: 999px;
    color: var(--text-2);
    background: rgba(0,0,0,0.3);
  }

  /* Code snippet */
  .code-snippet {
    margin-top: 1rem;
    padding: 1rem;
    background: rgba(0,0,0,0.5);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    font-size: 0.72rem;
    color: var(--text-2);
    line-height: 1.8;
    overflow-x: auto;
    white-space: pre;
  }

  /* MCP chat */
  .viz-mcp {
    margin-top: 1.25rem;
    background: rgba(0,0,0,0.4);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 1rem;
  }
  .mcp-q {
    font-size: 0.82rem;
    color: var(--text-2);
    margin-bottom: 0.75rem;
  }
  .mcp-a {
    font-size: 0.82rem;
    color: var(--text);
    padding-left: 1rem;
    border-left: 2px solid var(--accent);
  }

  /* ============================================
     HOW IT WORKS
     ============================================ */
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .step-n {
    font-size: 0.72rem;
    color: var(--accent);
    margin-bottom: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }
  .step h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .step p {
    color: var(--text-2);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .steps { grid-template-columns: 1fr; }
  }

  /* ============================================
     DASHBOARD MOCKUP
     ============================================ */
  .dashboard {
    background: var(--bg-2);
    border: 1px solid rgba(148,163,184,0.1);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }
  .db-top {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: rgba(0,0,0,0.4);
    border-bottom: 1px solid var(--border);
  }
  .db-lights { display: flex; gap: 6px; }
  .db-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
  }
  .db-dot-r { background: #ef4444; }
  .db-dot-y { background: #f59e0b; }
  .db-dot-g { background: #22c55e; }
  .db-url {
    flex: 1;
    text-align: center;
    font-size: 0.72rem;
    color: var(--text-3);
  }
  .db-actions {
    font-size: 0.72rem;
    color: var(--text-3);
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
  }
  .db-body {
    display: grid;
    grid-template-columns: 180px 1fr;
    min-height: 350px;
  }
  .db-side {
    padding: 1rem;
    border-right: 1px solid var(--border);
    background: rgba(0,0,0,0.2);
  }
  .db-side-label {
    font-size: 0.6rem;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    margin-top: 0.25rem;
  }
  .db-app {
    font-size: 0.78rem;
    padding: 0.4rem 0.6rem;
    border-radius: 0.35rem;
    color: var(--text-2);
    cursor: default;
    margin-bottom: 0.15rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .db-app-active {
    background: rgba(34,197,94,0.08);
    color: var(--text);
    border: 1px solid rgba(34,197,94,0.15);
  }
  .db-app-alert {
    color: var(--warn);
  }
  .db-badge-warn {
    font-size: 0.6rem;
    background: rgba(245,158,11,0.15);
    color: var(--warn);
    padding: 0.1rem 0.35rem;
    border-radius: 999px;
    margin-left: 0.25rem;
  }
  .db-side-divider {
    height: 1px;
    background: var(--border);
    margin: 0.75rem 0;
  }
  .db-filter {
    font-size: 0.75rem;
    padding: 0.35rem 0.6rem;
    border-radius: 0.35rem;
    color: var(--text-3);
    cursor: default;
    margin-bottom: 0.15rem;
  }
  .db-filter-active { color: var(--text-2); background: rgba(148,163,184,0.06); }

  .db-main { padding: 1.25rem; }
  .db-title {
    font-size: 1.1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  .db-env-badge {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    padding: 0.2rem 0.5rem;
    background: rgba(148,163,184,0.06);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-3);
    font-weight: 400;
  }
  .db-alert-badge {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    padding: 0.2rem 0.5rem;
    background: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.2);
    border-radius: 999px;
    color: var(--danger);
    font-weight: 600;
  }
  .db-kpis {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .db-kpi {
    background: rgba(0,0,0,0.3);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.75rem;
  }
  .db-kpi-label {
    font-size: 0.6rem;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.35rem;
  }
  .db-kpi-val {
    font-size: 1rem;
    font-weight: 700;
  }
  .db-kpi-val span { font-size: 0.72rem; font-weight: 500; }
  .db-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .db-panel {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .db-panel-head {
    font-size: 0.65rem;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--border);
    background: rgba(0,0,0,0.2);
  }
  .db-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.75rem;
  }
  .db-table td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-2);
  }
  .db-table td:first-child { color: var(--text); }
  .db-table td:last-child { text-align: right; }
  .db-row-fail td { background: rgba(239,68,68,0.04); }
  .db-row-warn td { background: rgba(245,158,11,0.04); }

  .sparkline-placeholder {
    width: 60px;
    height: 16px;
    background: linear-gradient(90deg, rgba(34,197,94,0.1), rgba(34,197,94,0.3));
    border-radius: 2px;
    display: inline-block;
    vertical-align: middle;
    float: right;
  }
  .sparkline-red {
    background: linear-gradient(90deg, rgba(239,68,68,0.1), rgba(239,68,68,0.4));
  }

  @media (max-width: 768px) {
    .db-body { grid-template-columns: 1fr; }
    .db-side { display: none; }
    .db-kpis { grid-template-columns: repeat(2, 1fr); }
    .db-panels { grid-template-columns: 1fr; }
  }

  /* ============================================
     INTEGRATIONS
     ============================================ */
  .integrations {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 48rem;
    margin: 0 auto;
  }
  .int-group h4 {
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text);
  }
  .int-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .int-pill {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid rgba(148,163,184,0.15);
    border-radius: 999px;
    color: var(--text-2);
    background: rgba(0,0,0,0.3);
  }
  .int-pill-muted {
    color: var(--text-3);
    border-color: rgba(148,163,184,0.08);
  }
  @media (max-width: 640px) {
    .integrations { grid-template-columns: 1fr; }
  }

  /* ============================================
     PRICING
     ============================================ */
  .billing-toggle {
    display: inline-flex;
    margin-top: 1.25rem;
    background: rgba(0,0,0,0.4);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.2rem;
  }
  .toggle-btn {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    padding: 0.4rem 1rem;
    border: none;
    border-radius: 0.35rem;
    background: transparent;
    color: var(--text-3);
    cursor: pointer;
    transition: all 0.2s;
  }
  .toggle-active {
    background: rgba(148,163,184,0.1);
    color: var(--text);
  }
  .toggle-save {
    font-size: 0.7rem;
    color: var(--accent);
    font-weight: 600;
  }

  .pricing {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 56rem;
    margin: 0 auto;
  }
  .pricing-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    position: relative;
  }
  .pricing-card-featured {
    border-color: rgba(34,197,94,0.3);
    background: linear-gradient(180deg, rgba(34,197,94,0.04) 0%, var(--bg-2) 40%);
  }
  .pricing-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2rem 0.75rem;
    background: var(--accent);
    color: #000;
    border-radius: 999px;
    white-space: nowrap;
  }
  .pricing-name {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .pricing-price {
    font-size: 2.5rem;
    font-weight: 800;
    font-family: var(--font-mono);
    margin-bottom: 1.5rem;
    line-height: 1;
  }
  .pricing-period {
    font-size: 0.9rem;
    color: var(--text-3);
    font-weight: 400;
  }
  .pricing-features {
    list-style: none;
    flex: 1;
    margin-bottom: 1.5rem;
  }
  .pricing-features li {
    font-size: 0.88rem;
    color: var(--text-2);
    padding: 0.35rem 0;
    padding-left: 1.2rem;
    position: relative;
  }
  .pricing-features li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.8rem;
  }
  .pricing-no {
    color: var(--text-3) !important;
  }
  .pricing-no::before {
    content: '\2014' !important;
    color: var(--text-3) !important;
  }
  .coming-soon {
    font-size: 0.6rem;
    font-family: var(--font-mono);
    color: var(--text-3);
    background: rgba(148,163,184,0.06);
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
    vertical-align: middle;
