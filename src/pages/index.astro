<!-- ========================================
     CLIENT-SIDE INTERACTIVITY
======================================== -->
<script>
  // ---- Scroll Reveal ----
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  reveals.forEach((el) => observer.observe(el));

  // ---- Nav scroll effect ----
  const nav = document.querySelector('header') as HTMLElement | null;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav?.classList.add('nav-scrolled');
    } else {
      nav?.classList.remove('nav-scrolled');
    }
  }, { passive: true });

  // ---- Pricing toggle ----
  const monthlyBtn = document.getElementById('toggle-monthly') as HTMLButtonElement;
  const yearlyBtn  = document.getElementById('toggle-yearly')  as HTMLButtonElement;
  const proPrice   = document.getElementById('pro-price')      as HTMLElement;
  const teamPrice  = document.getElementById('team-price')     as HTMLElement;
  const proNote    = document.getElementById('pro-note')       as HTMLElement;
  const teamNote   = document.getElementById('team-note')      as HTMLElement;

  const pricingData = {
    monthly: { pro: '$8',  team: '$29', proNote: '',        teamNote: '' },
    yearly:  { pro: '$6',  team: '$23', proNote: 'Billed $72/year', teamNote: 'Billed $276/year' },
  };

  function setActive(btn: HTMLButtonElement, other: HTMLButtonElement) {
    btn.classList.remove('pricing-btn-inactive');
    btn.classList.add('pricing-btn-active');
    other.classList.remove('pricing-btn-active');
    other.classList.add('pricing-btn-inactive');
  }

  monthlyBtn?.addEventListener('click', () => {
    const d = pricingData.monthly;
    proPrice.textContent = d.pro; teamPrice.textContent = d.team;
    proNote.textContent  = d.proNote; teamNote.textContent = d.teamNote;
    setActive(monthlyBtn, yearlyBtn);
  });

  yearlyBtn?.addEventListener('click', () => {
    const d = pricingData.yearly;
    proPrice.textContent = d.pro; teamPrice.textContent = d.team;
    proNote.textContent  = d.proNote; teamNote.textContent = d.teamNote;
    setActive(yearlyBtn, monthlyBtn);
  });

  // Init active state
  monthlyBtn?.classList.add('pricing-btn-active');
  yearlyBtn?.classList.add('pricing-btn-inactive');

  // ---- Copy install command ----
  const copyBtn   = document.getElementById('copy-btn');
  const copyIcon  = document.getElementById('copy-icon');
  const checkIcon = document.getElementById('check-icon');
  const installCmd = document.getElementById('install-cmd');

  copyBtn?.addEventListener('click', async () => {
    const text = installCmd?.textContent?.trim() ?? '';
    await navigator.clipboard.writeText(text);
    copyIcon?.classList.add('hidden');
    checkIcon?.classList.remove('hidden');
    setTimeout(() => {
      copyIcon?.classList.remove('hidden');
      checkIcon?.classList.add('hidden');
    }, 1500);
  });
</script>

<style>
  .pricing-btn-active {
    background: #22c55e;
    color: #000;
  }
  .pricing-btn-inactive {
    background: transparent;
    color: #525252;
  }
  .pricing-btn-inactive:hover {
    color: #a3a3a3;
  }
</style>

