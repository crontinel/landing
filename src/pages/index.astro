  }
  .pkg-lang {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.25rem 0.45rem;
    border-radius: 0.25rem;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }
  .pkg-ts { background: rgba(49,120,198,0.15); color: #60a5fa; }
  .pkg-py { background: rgba(255,212,59,0.12); color: #fbbf24; }
  .pkg-go { background: rgba(0,173,216,0.12); color: #22d3ee; }
  .pkg-rs { background: rgba(222,165,132,0.12); color: #fb923c; }
  .pkg-php { background: rgba(119,123,180,0.15); color: #a78bfa; }
  .pkg-la { background: rgba(239,68,68,0.12); color: #f87171; }
  .pkg-sh { background: rgba(148,163,184,0.12); color: #94a3b8; }
  .pkg-ai { background: rgba(34,197,94,0.12); color: #4ade80; }

  @media (max-width: 768px) {
    .pkg-grid { grid-template-columns: 1fr; }
  }

  .oss-cloud {
    background: linear-gradient(135deg, rgba(34,197,94,0.05) 0%, rgba(99,102,241,0.05) 100%);
    border: 1px solid rgba(34,197,94,0.15);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .oss-cloud-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .oss-cloud-copy {
    flex: 1;
    min-width: 200px;
  }
  .oss-cloud-copy h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }
  .oss-cloud-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.35rem 1.5rem;
    font-size: 0.82rem;
    color: var(--text-2);
  }
  .oss-cloud-features span { white-space: nowrap; }

  /* ============================================
     SDK TABS
     ============================================ */
  .sdk-tabs {
    max-width: 36rem;
    margin: 0 auto;
  }
  .sdk-tab-bar {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
    overflow-x: auto;
  }
  .sdk-tab {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.6rem 1rem;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--text-3);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.2s, border-color 0.2s;
  }
  .sdk-tab:hover { color: var(--text-2); }
  .sdk-tab-active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .sdk-panel {
    display: none;
  }
  .sdk-panel-active {
    display: block;
  }
  .sdk-cmd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(0,0,0,0.4);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    margin-bottom: 0.5rem;
  }
  .sdk-cmd code {
    font-size: 0.82rem;
    color: var(--text-2);
  }
  .copy-btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.25rem 0.6rem;
    background: rgba(148,163,184,0.08);
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    color: var(--text-3);
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
    margin-left: 0.75rem;
  }
  .copy-btn:hover {
    background: rgba(148,163,184,0.15);
    color: var(--text-2);
  }

  /* ============================================
     FINAL CTA
     ============================================ */
  .section-cta {
    padding: 8rem 0;
  }
  .final {
    text-align: center;
    max-width: 36rem;
    margin: 0 auto;
  }
  .final h2 {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .final p {
    color: var(--text-2);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .final-ctas {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ============================================
     FOOTER
     ============================================ */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 4rem 0 2rem;
    position: relative;
    overflow: hidden;
  }
  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr repeat(4, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }
  .footer-brand p {
    margin-top: 0.75rem;
  }
  .footer-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    color: var(--text-3);
    margin-top: 0.75rem;
  }
  .footer-social {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }
  .footer-social a {
    color: var(--text-3);
    transition: color 0.2s;
  }
  .footer-social a:hover { color: var(--text-2); }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-heading {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
    margin-bottom: 0.25rem;
    font-weight: 600;
  }
  .footer-col a {
    font-size: 0.85rem;
    color: var(--text-2);
    transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--text); }

  .footer-wordmark {
    font-family: var(--font-mono);
    font-size: clamp(4rem, 12vw, 10rem);
    font-weight: 800;
    text-align: center;
    color: rgba(148,163,184,0.03);
    line-height: 1;
    margin-bottom: 1.5rem;
    user-select: none;
    pointer-events: none;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
    font-size: 0.75rem;
    color: var(--text-3);
  }

  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: span 2;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
  @media (max-width: 480px) {
    .footer-top { grid-template-columns: 1fr; }
    .footer-brand { grid-column: span 1; }
  }

  /* ============================================
     SCROLL REVEAL
     ============================================ */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1),
                transform 0.7s cubic-bezier(0.16,1,0.3,1);
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }

  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; }
  }
</style>

<script is:inline>
(function() {
  'use strict';

  /* ==== NAV SCROLL ==== */
  var nav = document.querySelector('.nav');
  window.addEventListener('scroll', function() {
    if (window.scrollY > 20) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  }, { passive: true });

  /* ==== NAV TOGGLE ==== */
  var toggleBtn = document.querySelector('.nav-toggle');
  var mobileMenu = document.getElementById('nav-mobile');
  var hamburgerIcon = document.querySelector('.hamburger-icon');
  var closeIcon = document.querySelector('.close-icon');
  if (toggleBtn) {
    toggleBtn.addEventListener('click', function() {
      var isOpen = mobileMenu.classList.contains('open');
      mobileMenu.classList.toggle('open', !isOpen);
      hamburgerIcon.style.display = isOpen ? '' : 'none';
      closeIcon.style.display = isOpen ? 'none' : '';
      toggleBtn.setAttribute('aria-expanded', String(!isOpen));
    });
    mobileMenu.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', function() {
        mobileMenu.classList.remove('open');
        hamburgerIcon.style.display = '';
        closeIcon.style.display = 'none';
        toggleBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }

  /* ==== HEARTBEAT CHART ==== */
  var points = [];
  var numPoints = 60;
  var svgW = 600, svgH = 120;
  for (var i = 0; i < numPoints; i++) {
    points.push(svgH * 0.5 + (Math.random() - 0.5) * svgH * 0.4);
  }

  function drawHeartbeat() {
    var line = document.getElementById('heartbeat-line');
    var area = document.getElementById('heartbeat-area');
    var dot = document.getElementById('heartbeat-dot');
    if (!line) return;

    var stepX = svgW / (numPoints - 1);
    var d = 'M0,' + points[0].toFixed(1);
    for (var i = 1; i < numPoints; i++) {
      var x = i * stepX;
      var y = points[i];
      var px = (i - 1) * stepX;
      var py = points[i - 1];
      var cx1 = px + stepX * 0.4;
      var cx2 = x - stepX * 0.4;
      d += ' C' + cx1.toFixed(1) + ',' + py.toFixed(1) + ' ' + cx2.toFixed(1) + ',' + y.toFixed(1) + ' ' + x.toFixed(1) + ',' + y.toFixed(1);
    }
    line.setAttribute('d', d);
    area.setAttribute('d', d + ' L' + svgW + ',' + svgH + ' L0,' + svgH + ' Z');
    var lastX = (numPoints - 1) * stepX;
    var lastY = points[numPoints - 1];
    dot.setAttribute('cx', lastX.toFixed(1));
    dot.setAttribute('cy', lastY.toFixed(1));
  }

  function updateHeartbeat() {
    points.shift();
    var last = points[points.length - 1];
    var isSpike = Math.random() < 0.08;
    var newVal;
    if (isSpike) {
      newVal = svgH * 0.15 + Math.random() * svgH * 0.2;
    } else {
      newVal = last + (Math.random() - 0.5) * 15;
      newVal = Math.max(svgH * 0.25, Math.min(svgH * 0.85, newVal));
    }
    points.push(newVal);
    drawHeartbeat();
  }
  drawHeartbeat();
  setInterval(updateHeartbeat, 1500);

  /* ==== EVENT FEED ==== */
  var feedEvents = [
    { type: 'ok', name: 'schedule:run', msg: 'completed in 842ms' },
    { type: 'ok', name: 'worker.default', msg: '2 supervisors running' },
    { type: 'warn', name: 'queue.emails', msg: 'depth 6,413 backpressure' },
    { type: 'fail', name: 'sync:stripe-webhooks', msg: 'exit 1 retry 3/5' },
    { type: 'ok', name: 'generate:daily-invoices', msg: 'ok 2m 14s' },
    { type: 'ok', name: 'agent.support', msg: '12 runs p95 8.2s' },
    { type: 'warn', name: 'telemetry:roll-up', msg: 'slow 8m 02s' },
    { type: 'ok', name: 'cleanup:stale-sessions', msg: 'ok 1m 08s' },
    { type: 'fail', name: 'agent.run.874', msg: '42m 318 tool calls killed' },
    { type: 'ok', name: 'dunning:send-reminders', msg: 'ok 48s' },
  ];
  var feedIdx = 0;
  var feedEl = document.getElementById('monitor-feed');

  function addFeedEvent() {
    if (!feedEl) return;
    var ev = feedEvents[feedIdx % feedEvents.length];
    feedIdx++;
    var row = document.createElement('div');
    row.className = 'feed-row';
    var dotClass = ev.type === 'ok' ? 'dot-ok' : ev.type === 'fail' ? 'dot-fail' : 'dot-warn';
    var now = new Date();
    var time = String(now.getHours()).padStart(2,'0') + ':' + String(now.getMinutes()).padStart(2,'0') + ':' + String(now.getSeconds()).padStart(2,'0');
    row.innerHTML = '<span class="dot ' + dotClass + '"></span>' +
      '<span>' + ev.name + '</span>' +
      '<span style="color:var(--text-3);margin-left:0.5rem">' + ev.msg + '</span>' +
      '<span class="feed-time">' + time + '</span>';
    feedEl.insertBefore(row, feedEl.firstChild);
    while (feedEl.children.length > 6) {
      feedEl.removeChild(feedEl.lastChild);
    }
  }
  addFeedEvent();
  setInterval(addFeedEvent, 2500);

  /* ==== WORKER GRID ==== */
  var workerNames = ['default', 'invoices', 'emails', 'analytics', 'notifications', 'payments', 'reports', 'webhooks',
                     'imports', 'exports', 'search', 'cache', 'mailer', 'billing', 'telemetry', 'agent'];
  var workerStates = ['busy', 'busy', 'busy', 'idle', 'busy', 'busy', 'idle', 'busy',
                      'paused', 'busy', 'busy', 'idle', 'busy', 'busy', 'idle', 'busy'];
  var workerGrid = document.getElementById('worker-grid');

  function renderWorkers() {
    if (!workerGrid) return;
    workerGrid.innerHTML = '';
    for (var i = 0; i < 16; i++) {
      var cell = document.createElement('div');
      cell.className = 'worker-cell ' + workerStates[i];
      var dotClass = workerStates[i] === 'busy' ? 'dot-ok' : workerStates[i] === 'paused' ? 'dot-warn' : '';
      cell.innerHTML = '<span class="dot ' + dotClass + '" style="width:6px;height:6px"></span>' + workerNames[i];
      workerGrid.appendChild(cell);
    }
  }

  function updateWorkers() {
    for (var i = 0; i < 16; i++) {
      if (Math.random() < 0.15) {
        var r = Math.random();
        workerStates[i] = r < 0.6 ? 'busy' : r < 0.85 ? 'idle' : 'paused';
      }
    }
    renderWorkers();
  }
  renderWorkers();
  setInterval(updateWorkers, 3000);

  /* ==== COUNTER ANIMATION ==== */
  function animateCounter(el) {
    var target = parseInt(el.getAttribute('data-count'), 10);
    var duration = 1500;
    var start = performance.now();
    function step(now) {
      var progress = Math.min((now - start) / duration, 1);
      var eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(target * eased);
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  var counterObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        animateCounter(entry.target);
        counterObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('.val[data-count]').forEach(function(el) {
    counterObserver.observe(el);
  });

  /* ==== SCROLL REVEAL ==== */
  var revealObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.reveal').forEach(function(el) {
    revealObserver.observe(el);
  });

  /* ==== SDK TABS ==== */
  var tabBar = document.getElementById('sdk-tab-bar');
  if (tabBar) {
    tabBar.addEventListener('click', function(e) {
      var tab = e.target.closest('.sdk-tab');
      if (!tab) return;
      var target = tab.getAttribute('data-tab');
      document.querySelectorAll('.sdk-tab').forEach(function(t) { t.classList.remove('sdk-tab-active'); });
      document.querySelectorAll('.sdk-panel').forEach(function(p) { p.classList.remove('sdk-panel-active'); });
      tab.classList.add('sdk-tab-active');
      var panel = document.querySelector('.sdk-panel[data-panel="' + target + '"]');
      if (panel) panel.classList.add('sdk-panel-active');
    });
  }

  /* ==== BILLING TOGGLE ==== */
  var billingToggle = document.getElementById('billing-toggle');
  if (billingToggle) {
    billingToggle.addEventListener('click', function(e) {
      var btn = e.target.closest('.toggle-btn');
      if (!btn) return;
      var period = btn.getAttribute('data-period');
      billingToggle.querySelectorAll('.toggle-btn').forEach(function(b) { b.classList.remove('toggle-active'); });
      btn.classList.add('toggle-active');
      document.querySelectorAll('.price-val').forEach(function(el) {
        el.textContent = el.getAttribute('data-' + period);
      });
    });
  }

  /* ==== COPY BUTTONS ==== */
  document.querySelectorAll('.copy-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var text = btn.getAttribute('data-copy');
      navigator.clipboard.writeText(text).then(function() {
        var orig = btn.textContent;
        btn.textContent = 'Copied!';
        btn.style.color = 'var(--accent)';
        setTimeout(function() {
          btn.textContent = orig;
          btn.style.color = '';
        }, 1500);
      });
    });
  });

  /* ==== SMOOTH SCROLL ==== */
  document.querySelectorAll('a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.querySelector(a.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

})();
</script>

