<!-- HERO -->
<header class="hero">
  <div class="hero-bg">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="hero-scanline"></div>
  </div>
  <div class="container hero-content">
    <div class="hero-left">
      <span class="hero-status mono">
        <span class="dot dot-ok pulse"></span>
        all.systems.operational &middot; 99.987% last 30d
      </span>
      <h1>Your cron<br/>is <span class="accent">lying</span><br/>to you<span class="cursor">|</span></h1>
      <p class="hero-sub">Crontinel watches the jobs, queues, workers, models and agents behind your app, so you hear about the failure <em>before</em> your users do.</p>
      <div class="hero-ctas">
        <a class="btn btn-primary" href="https://app.crontinel.com">Start monitoring free &#8599;</a>
        <a class="btn btn-ghost" href="https://github.com/crontinel/crontinel" target="_blank" rel="noopener">View on GitHub</a>
      </div>
      <div class="hero-trust mono">node &middot; python &middot; go &middot; php &middot; cli &middot; MIT licensed &middot; free tier, no card</div>
    </div>
    <div class="hero-right">
      <div class="monitor">
        <div class="monitor-head mono">
          <span>live.monitor &middot; app.crontinel.com</span>
          <span class="monitor-stats">jobs: 1,847 &middot; latency: 42ms</span>
        </div>
        <div class="monitor-graph">
          <svg id="heartbeat-svg" viewBox="0 0 600 120" preserveAspectRatio="none">
            <defs>
              <linearGradient id="lineGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#22c55e" stop-opacity="0.1"/>
                <stop offset="100%" stop-color="#22c55e" stop-opacity="1"/>
              </linearGradient>
              <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#22c55e" stop-opacity="0.15"/>
                <stop offset="100%" stop-color="#22c55e" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <path id="heartbeat-area" fill="url(#areaGrad)" d=""/>
            <path id="heartbeat-line" fill="none" stroke="url(#lineGrad)" stroke-width="2" d=""/>
            <circle id="heartbeat-dot" r="4" fill="#22c55e" cx="0" cy="0">
              <animate attributeName="opacity" values="1;0.4;1" dur="1.5s" repeatCount="indefinite"/>
            </circle>
          </svg>
        </div>
        <div class="monitor-feed" id="monitor-feed"></div>
      </div>
      <div class="hero-captions mono">
        <span><span class="dot dot-ok"></span> heartbeat &middot; every 60s</span>
        <span><span class="dot dot-fail"></span> failure &middot; detected in &lt; 60s</span>
        <span><span class="dot dot-warn"></span> drift &middot; scheduler out of sync</span>
      </div>
    </div>
  </div>
</header>

<!-- METRICS -->
<section class="section-metrics reveal">
  <div class="container">
    <div class="metrics">
      <div class="metric">
        <div class="metric-n"><span class="val" data-count="62">0</span><span class="unit">s</span></div>
        <div class="metric-l">avg time to detect a silent cron failure</div>
      </div>
      <div class="metric">
        <div class="metric-n"><span class="val" data-count="14">0</span><span class="unit">%</span></div>
        <div class="metric-l">of production apps run a silently broken job</div>
      </div>
      <div class="metric">
        <div class="metric-n"><span class="val" data-count="2">0</span><span class="unit"> cmds</span></div>
        <div class="metric-l">to monitor jobs, queues, workers &amp; agents</div>
      </div>
      <div class="metric">
        <div class="metric-n">$<span class="val" data-count="19">0</span><span class="unit">/mo</span></div>
        <div class="metric-l">starts at, or self-host for free</div>
      </div>
    </div>
  </div>
</section>

<!-- PROBLEM -->
<section id="sec-problem" class="section">
  <div class="container">
    <div class="section-head-split reveal">
      <div class="section-head-copy">
        <span class="eyebrow">The gap</span>
        <h2>Your uptime monitor says <span class="ok-green">green</span>.<br/>Your queue disagrees.</h2>
        <p>A URL responding 200 doesn't mean your cron ran. It doesn't mean your workers are draining. It doesn't mean your <span class="mono accent">invoices</span> queue isn't 6,000 deep, or that your agent isn't looping on a broken tool call. Generic monitors can't tell you any of that.</p>
      </div>
      <aside class="section-head-aside">
        <div class="gap-wall">
          <div class="gap-col">
            <div class="gap-label mono">uptime.check</div>
            <div class="gap-item gap-ok"><span class="dot dot-ok"></span><span class="mono">GET /health</span><span class="gap-val ok-green">200</span></div>
            <div class="gap-item gap-ok"><span class="dot dot-ok"></span><span class="mono">GET /api/v1</span><span class="gap-val ok-green">200</span></div>
            <div class="gap-item gap-ok"><span class="dot dot-ok"></span><span class="mono">GET /login</span><span class="gap-val ok-green">200</span></div>
            <div class="gap-item gap-ok"><span class="dot dot-ok"></span><span class="mono">TLS valid</span><span class="gap-val ok-green">&#10003;</span></div>
          </div>
          <div class="gap-divider">vs</div>
          <div class="gap-col gap-col-truth">
            <div class="gap-label mono">crontinel</div>
            <div class="gap-item gap-bad"><span class="dot dot-fail"></span><span class="mono">schedule:run</span><span class="gap-val danger">17h late</span></div>
            <div class="gap-item gap-bad"><span class="dot dot-fail"></span><span class="mono">agent.run.874</span><span class="gap-val danger">42m loop</span></div>
            <div class="gap-item gap-bad"><span class="dot dot-warn"></span><span class="mono">queue:invoices</span><span class="gap-val warn">6.2k deep</span></div>
            <div class="gap-item gap-ok"><span class="dot dot-ok"></span><span class="mono">worker.main</span><span class="gap-val ok-green">ok</span></div>
          </div>
        </div>
      </aside>
    </div>
    <div class="problem-grid">
      <article class="card problem reveal">
        <div class="pico"><span class="dot dot-warn"></span><span class="mono">scheduled.task</span></div>
        <h3>Scheduler stops. Site stays up.</h3>
        <p>A deploy clobbers your cron entry. The app responds 200. No one fires the scheduler. Your nightly emails stop.</p>
        <pre class="mono">GET /health         200 ok
schedule:run        &middot; 17h ago</pre>
      </article>
      <article class="card problem reveal reveal-delay-1">
        <div class="pico"><span class="dot dot-fail"></span><span class="mono">agent.loop</span></div>
        <h3>The agent loops. The bill climbs.</h3>
        <p>A model retry storm or a tool-call loop runs for 40 minutes. The endpoint returns 200 for every request. You find out from billing.</p>
        <pre class="mono">api.status          200 ok
agent.run.874       42m &middot; 318 tool calls</pre>
      </article>
      <article class="card problem reveal reveal-delay-2">
        <div class="pico"><span class="dot dot-warn"></span><span class="mono">queue.backpressure</span></div>
        <h3>A downstream API throttles.</h3>
        <p>Your invoices queue is backing up silently. No alert fires because no job has failed. Customers are just waiting.</p>
        <pre class="mono">invoices.depth      127 &rarr; 6,413
oldest_job          12m 04s</pre>
      </article>
    </div>
  </div>
</section>

<!-- FEATURES BENTO -->
<section id="features" class="section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Everything uptime tools miss</span>
      <h2>Paranoid monitoring,<br/>without the instrumentation.</h2>
      <p>One SDK hooks into your scheduler, queue driver and agent runner. It watches job runs, queue depth, worker state, model latency and agent tool calls, end to end. No endpoint pings. No per-task wrapping. No missed instrumentation.</p>
    </div>
    <div class="bento">
      <!-- Large: Workers -->
      <article class="card b b-lg reveal">
        <h3>See the worker, not just the URL.</h3>
        <p>Per-worker status, paused detection, queue sparklines. Horizon, Sidekiq, Celery, BullMQ. The moment one blinks, you know.</p>
        <div class="horizon-grid" id="worker-grid"></div>
      </article>
      <!-- Medium: Heartbeat -->
      <article class="card b b-md reveal reveal-delay-1">
        <h3>60-second detection.</h3>
        <p>Every scheduled task registers a run attempt, exit code, and duration. Missed runs trip an alert before the next cron tick.</p>
        <div class="viz-ping">
          <span class="mono">pulse</span>
          <div class="wave">
            <span class="wave-ring"></span>
            <span class="wave-ring wave-ring-2"></span>
            <span class="wave-ring wave-ring-3"></span>
          </div>
          <span class="accent mono">60s</span>
        </div>
      </article>
      <!-- Small: Zero wrap -->
      <article class="card b b-sm reveal reveal-delay-2">
        <h3>No per-task instrumentation.</h3>
        <p>Hooks into your framework's events, not your code.</p>
      </article>
      <!-- Small: Self-hosted -->
      <article class="card b b-sm reveal reveal-delay-3">
        <h3>Works offline. MIT.</h3>
        <p>OSS first. Local dashboard, CLI, no SaaS needed.</p>
      </article>
      <!-- Medium: Alert channels -->
      <article class="card b b-md reveal">
        <h3>Route once, quiet forever.</h3>
        <p>One alert fans out to the channels your team watches — per-service routing, quiet hours, auto-resolve.</p>
        <div class="viz-channels">
          <span class="channel-pill">Slack</span>
          <span class="channel-pill">PagerDuty</span>
          <span class="channel-pill">Webhook</span>
          <span class="channel-pill">Email</span>
        </div>
      </article>
      <!-- Medium: CI/CD check -->
      <article class="card b b-md reveal reveal-delay-1">
        <h3>crontinel:check in your deploy hook.</h3>
        <p>One command verifies scheduler, supervisors and queues after each deploy.</p>
        <pre class="mono code-snippet">$ crontinel check
<span class="ok-green">&#10003;</span> scheduler           last run 00:00:12 ago
<span class="ok-green">&#10003;</span> workers.default     2 supervisors &middot; running
<span class="ok-green">&#10003;</span> queue.invoices      127 pending &middot; 2m oldest
<span class="ok-green">&#10003;</span> agents.support      12 runs &middot; p95 8.2s
<span class="danger">&#10007;</span> queue.emails        backpressure &middot; 6,413 pending</pre>
      </article>
      <!-- Wide: Agents & MCP -->
      <article class="card b b-wide reveal">
        <h3>Monitor the agent like any other worker.</h3>
        <p>Track runs, tool calls, token spend, model latency and loop detection. Ask via MCP.</p>
        <div class="viz-mcp">
          <div class="mcp-q mono"><span class="accent">&#8250;</span> are any queues backing up?</div>
          <div class="mcp-a mono">Yes &middot; <span class="danger">emails</span> is at 6,413 and rising. Oldest job 12m 04s. <span class="ok-green">invoices</span> is healthy.</div>
        </div>
      </article>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section id="how" class="section">
  <div class="container">
    <div class="section-head reveal">
      <h2>Two commands.<br/>One source of truth.</h2>
    </div>
    <div class="steps">
      <div class="step reveal">
        <div class="step-n mono">01 &middot; INSTALL</div>
        <h3>One SDK, your stack</h3>
        <p>Drop the SDK in. No scheduler wrapping. No per-job decorators.</p>
        <pre class="mono code-snippet"><span class="text-3"># pick your runtime</span>
$ npm i @crontinel/node
$ pip install crontinel
$ go get github.com/crontinel/go</pre>
      </div>
      <div class="step reveal reveal-delay-1">
        <div class="step-n mono">02 &middot; ROUTE ALERTS</div>
        <h3>Pick a channel</h3>
        <p>Slack, PagerDuty, email, webhook. HMAC-signed. Quiet hours.</p>
        <pre class="mono code-snippet"><span class="text-3"># .env</span>
CRONTINEL_ALERT_CHANNEL=slack
CRONTINEL_SLACK_WEBHOOK=...</pre>
      </div>
      <div class="step reveal reveal-delay-2">
        <div class="step-n mono">03 &middot; SLEEP</div>
        <h3>Listen instead of watch</h3>
        <p>When something drifts, you hear from us, not a user.</p>
        <pre class="mono code-snippet"><span class="text-3"># ci/cd deploy hook</span>
$ crontinel check
<span class="ok-green">&#10003;</span> 47 jobs &middot; 3 workers &middot; 2 queues &middot; 4 agents</pre>
      </div>
    </div>
  </div>
</section>

<!-- DASHBOARD MOCKUP -->
<section id="dashboard" class="section">
  <div class="container">
    <div class="section-head reveal">
      <h2>Not a heartbeat ping chart.<br/>The inside of your queue.</h2>
      <p>Every scheduled task with its last run, duration and exit code. Every worker with its state. Every queue with depth, oldest job, and failure rate.</p>
    </div>
    <div class="dashboard reveal">
      <div class="db-top">
        <div class="db-lights"><span class="db-dot db-dot-r"></span><span class="db-dot db-dot-y"></span><span class="db-dot db-dot-g"></span></div>
        <div class="db-url mono">app.crontinel.com/invoice-processor</div>
        <div class="db-actions mono">&#8984;K</div>
      </div>
      <div class="db-body">
        <aside class="db-side">
          <div class="db-side-label mono">APPS</div>
          <div class="db-app">customer-portal</div>
          <div class="db-app db-app-active">invoice-processor</div>
          <div class="db-app db-app-alert">notifications <span class="db-badge-warn">2</span></div>
          <div class="db-app">analytics-etl</div>
          <div class="db-app">billing-webhooks</div>
          <div class="db-side-divider"></div>
          <div class="db-side-label mono">FILTER</div>
          <div class="db-filter db-filter-active">All statuses</div>
          <div class="db-filter">Alerts only</div>
        </aside>
        <div class="db-main">
          <div class="db-title">
            invoice-processor
            <span class="db-env-badge">production &middot; eu-west-1</span>
            <span class="db-alert-badge">1 alert</span>
          </div>
          <div class="db-kpis">
            <div class="db-kpi">
              <div class="db-kpi-label mono">schedule runs/24h</div>
              <div class="db-kpi-val">1,447 <span class="ok-green">+2.1%</span></div>
            </div>
            <div class="db-kpi">
              <div class="db-kpi-label mono">avg run time</div>
              <div class="db-kpi-val">842ms <span class="ok-green">&minus;120ms</span></div>
            </div>
            <div class="db-kpi">
              <div class="db-kpi-label mono">queue depth</div>
              <div class="db-kpi-val">241 <span class="ok-green">healthy</span></div>
            </div>
            <div class="db-kpi">
              <div class="db-kpi-label mono">failed last 1h</div>
              <div class="db-kpi-val">12 <span class="danger">+12 vs 0</span></div>
            </div>
          </div>
          <div class="db-panels">
            <div class="db-panel">
              <div class="db-panel-head mono">Scheduled tasks</div>
              <table class="db-table">
                <tbody>
                  <tr><td class="mono">generate:daily-invoices</td><td><span class="dot dot-ok"></span> ok</td><td class="mono text-3">2m 14s</td></tr>
                  <tr><td class="mono">dunning:send-reminders</td><td><span class="dot dot-ok"></span> ok</td><td class="mono text-3">48s</td></tr>
                  <tr class="db-row-fail"><td class="mono">sync:stripe-webhooks</td><td><span class="dot dot-fail"></span> exit 1</td><td class="mono text-3">12s</td></tr>
                  <tr><td class="mono">export:accounting-feed</td><td><span class="dot dot-ok"></span> ok</td><td class="mono text-3">3m 41s</td></tr>
                  <tr class="db-row-warn"><td class="mono">telemetry:roll-up</td><td><span class="dot dot-warn"></span> slow</td><td class="mono text-3">8m 02s</td></tr>
                  <tr><td class="mono">cleanup:stale-sessions</td><td><span class="dot dot-ok"></span> ok</td><td class="mono text-3">1m 08s</td></tr>
                </tbody>
              </table>
            </div>
            <div class="db-panel">
              <div class="db-panel-head mono">Workers &amp; queues</div>
              <table class="db-table">
                <tbody>
                  <tr><td class="mono">default</td><td class="mono">12</td><td><div class="sparkline-placeholder"></div></td></tr>
                  <tr><td class="mono">invoices</td><td class="mono">127</td><td><div class="sparkline-placeholder"></div></td></tr>
                  <tr class="db-row-fail"><td class="mono">emails</td><td class="mono danger">6,413</td><td><div class="sparkline-placeholder sparkline-red"></div></td></tr>
                  <tr><td class="mono">analytics</td><td class="mono">88</td><td><div class="sparkline-placeholder"></div></td></tr>
                  <tr><td class="mono">notifications</td><td class="mono">3</td><td><div class="sparkline-placeholder"></div></td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- INTEGRATIONS -->
<section id="sec-integrations" class="section">
  <div class="container">
    <div class="section-head reveal">
      <h2>Alerts go where you listen.</h2>
    </div>
    <div class="integrations reveal">
      <div class="card int-group">
        <h4>Native &middot; shipping</h4>
        <div class="int-pills">
          <span class="int-pill">Slack</span>
          <span class="int-pill">PagerDuty</span>
          <span class="int-pill">Email / SES</span>
          <span class="int-pill">Webhook &middot; HMAC</span>
          <span class="int-pill">Telegram</span>
          <span class="int-pill">MCP &middot; any agent</span>
        </div>
      </div>
      <div class="card int-group">
        <h4>Coming soon</h4>
        <div class="int-pills">
          <span class="int-pill int-pill-muted">Discord</span>
          <span class="int-pill int-pill-muted">Opsgenie</span>
          <span class="int-pill int-pill-muted">Linear</span>
          <span class="int-pill int-pill-muted">Zapier</span>
          <span class="int-pill int-pill-muted">Microsoft Teams</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section id="pricing" class="section">
  <div class="container">
    <div class="section-head reveal">
      <h2>Free for one app.<br/>Generous for teams.</h2>
      <div class="billing-toggle" id="billing-toggle">
        <button class="toggle-btn toggle-active" data-period="monthly">Monthly</button>
        <button class="toggle-btn" data-period="yearly">Yearly <span class="toggle-save">&minus;20%</span></button>
      </div>
    </div>
    <div class="pricing reveal">
