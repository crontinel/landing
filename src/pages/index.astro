---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<script type="application/ld+json" slot="head">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Crontinel",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Laravel",
  "description": "Cron, scheduler, and background job health monitoring for Laravel applications. Detects failures, late runs, and queue issues that generic uptime tools miss.",
  "url": "https://crontinel.com",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "description": "Free plan with 1 app, 5 monitors, 7-day history"
  },
  "featureList": [
    "Cron job health monitoring",
    "Laravel Horizon queue monitoring",
    "Background job failure detection",
    "Slack, email, PagerDuty, and webhook alerts",
    "Public status pages",
    "14-day alert history",
    "REST API access",
    "Self-hosted MIT option"
  ],
  "provider": { "@type": "Organization", "@id": "https://crontinel.com/#organization" }
}
</script>

<script type="application/ld+json" slot="head">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://crontinel.com" }]
}
</script>

<Base
  title="Crontinel - Cron, Scheduler & Background Job Monitoring for Laravel"
  description="Know when your cron jobs, schedulers, and background jobs stop working — before your customers do. Health monitoring that generic uptime tools miss."
>
  <Nav />

  <main id="main-content">

    <!-- ========================================
         HERO
    ======================================== -->
    <section class="relative overflow-hidden pt-24 pb-20 md:pt-32 md:pb-28">
      <!-- Background layers -->
      <div class="absolute inset-0 dot-grid opacity-40"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[500px] rounded-full"
           style="background: radial-gradient(ellipse at center, rgba(34,197,94,0.08) 0%, transparent 70%); animation: heroGlow 8s ease-in-out infinite;"></div>
      <div class="absolute top-20 right-1/4 w-[300px] h-[300px] rounded-full opacity-20"
           style="background: radial-gradient(ellipse, rgba(34,197,94,0.06) 0%, transparent 70%); animation: heroFloat 12s ease-in-out infinite;"></div>

      <div class="relative max-w-5xl mx-auto px-4 sm:px-6 text-center">

        <!-- Badge -->
        <div class="reveal inline-flex items-center gap-2 text-xs font-medium px-3 py-1 rounded-full mb-8"
             style="background:rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.2); color: #22c55e;">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75"
                  style="background:#22c55e; animation-duration: 2s;"></span>
            <span class="relative inline-flex rounded-full h-2 w-2" style="background:#22c55e;"></span>
          </span>
          Built for Laravel — Open source + hosted
        </div>

        <!-- Headline -->
        <h1 class="reveal reveal-delay-1 text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05] mb-6">
          Never miss a<br class="hidden sm:block" />
          <span class="gradient-accent">failed cron</span><br class="hidden sm:block" />
          again.
        </h1>

        <!-- Subheadline -->
        <p class="reveal reveal-delay-2 text-lg md:text-xl text-[#a3a3a3] max-w-2xl mx-auto mb-10 leading-relaxed">
          Crontinel monitors your cron jobs, schedulers, and background queues —
          the things uptime tools simply can't see.
        </p>

        <!-- CTAs -->
        <div class="reveal reveal-delay-3 flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
          <a href="https://app.crontinel.com/register"
             class="w-full sm:w-auto text-center text-sm font-semibold px-6 py-3 rounded-lg transition-all duration-200"
             style="background:#22c55e; color:#000;"
             onmouseover="this.style.background='#16a34a'"
             onmouseout="this.style.background='#22c55e'">
            Start monitoring free
          </a>
          <a href="https://github.com/crontinel/crontinel"
             target="_blank" rel="noopener"
             class="w-full sm:w-auto text-center text-sm font-medium px-6 py-3 rounded-lg transition-all duration-200 border"
             style="border-color:#2a2a2a; color:#a3a3a3;"
             onmouseover="this.style.borderColor='#525252'; this.style.color='#fff'"
             onmouseout="this.style.borderColor='#2a2a2a'; this.style.color='#a3a3a3'">
            <span class="flex items-center justify-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              View on GitHub
            </span>
          </a>
        </div>

        <!-- Trust strip -->
        <p class="reveal reveal-delay-4 text-xs text-[#525252] flex items-center justify-center gap-3 flex-wrap">
          <span>Free plan forever</span>
          <span style="width:1px;height:10px;background:#2a2a2a;display:inline-block;"></span>
          <span>No credit card required</span>
          <span style="width:1px;height:10px;background:#2a2a2a;display:inline-block;"></span>
          <span>MIT open-source package</span>
          <span style="width:1px;height:10px;background:#2a2a2a;display:inline-block;"></span>
          <span>14-day Pro trial included</span>
        </p>
      </div>
    </section>


    <!-- ========================================
         METRICS STRIP
    ======================================== -->
    <section class="border-y" style="border-color:#1c1c1c; background:#0c0c0c;">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
        <div class="grid grid-cols-3 divide-x text-center" style="divide-color:#1c1c1c;">
          {[
            { value: 'Laravel', label: 'Built exclusively for' },
            { value: '1 app · 5 monitors', label: 'Free plan includes' },
            { value: '14-day', label: 'Pro trial, no card needed' },
          ].map((m, i) => (
            <div class={`reveal reveal-delay-${i + 1} px-4`}>
              <div class="text-lg md:text-xl font-bold text-white mb-0.5">{m.value}</div>
              <div class="text-xs text-[#525252]">{m.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ========================================
         PROBLEM
    ======================================== -->
    <section class="py-24 md:py-28">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-14">
          <p class="reveal text-xs font-semibold tracking-[0.15em] uppercase text-[#525252] mb-4">The Problem</p>
          <h2 class="reveal reveal-delay-1 text-3xl md:text-4xl font-bold tracking-tight text-white leading-tight">
            Your uptime monitor says <span class="text-[#ef4444]">green</span>.<br />
            Your queue has been dead for hours.
          </h2>
          <p class="reveal reveal-delay-2 text-[#a3a3a3] mt-4 max-w-xl mx-auto">
            Ping-based monitors confirm a process started — not that it worked, or that your workers are still alive.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {[
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
              title: 'Silent cron failures',
              desc: 'Your send-invoices job has been failing silently for 3 days. The generic monitor shows green because the cron process started — even though the command inside it crashed.',
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
              title: 'Queue backlog accumulation',
              desc: 'The emails queue has 8,000 jobs pending. Nobody knows until customers start complaining that they didn\'t receive their order confirmations.',
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
              title: 'Worker process crashes',
              desc: 'A Horizon supervisor died. Your queue shows "running" because one worker is still up. Your invoice queue is completely stuck with no alerts firing.',
            },
          ].map((card, i) => (
            <div class={`reveal reveal-delay-${i + 1} card p-7`}>
              <div class="mb-4 p-2 w-fit rounded-lg" style="background: rgba(239,68,68,0.06);">
                <Fragment set:html={card.icon} />
              </div>
              <h3 class="text-base font-semibold text-white mb-2">{card.title}</h3>
              <p class="text-sm text-[#a3a3a3] leading-relaxed">{card.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ========================================
         FEATURES — BENTO GRID
    ======================================== -->
    <section class="py-24 md:py-28" style="background:#0c0c0c;">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-14">
          <p class="reveal text-xs font-semibold tracking-[0.15em] uppercase text-[#525252] mb-4">Everything You Need</p>
          <h2 class="reveal reveal-delay-1 text-3xl md:text-4xl font-bold tracking-tight text-white leading-tight">
            Monitor what uptime tools <span class="gradient-accent">miss</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <!-- Large feature cards (span 2 cols) -->
          {[
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
              title: 'Deep queue internals, not just pings',
              desc: 'Crontinel reads worker state directly from Redis — which supervisors are running, failed job rate, queue depths, whether Horizon is paused. Uptime monitors can\'t see this.',
              badge: 'Unique to Crontinel',
              large: true,
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
              title: 'Queue depth & age alerts',
              desc: 'Get notified when your queue depth exceeds a threshold, when jobs are older than expected, or when the failed job count spikes. Configurable per queue.',
              large: true,
            },
          ].map((f, i) => (
            <div class={`reveal reveal-delay-${i + 1} card p-7 ${f.large ? 'md:col-span-2' : ''}`}
                 style={f.large ? 'border-top: 2px solid rgba(34,197,94,0.4);' : ''}>
              {f.badge && (
                <span class="inline-block text-xs font-medium px-2 py-0.5 rounded-full mb-3"
                      style="background:rgba(34,197,94,0.1); border:1px solid rgba(34,197,94,0.2); color:#22c55e;">
                  {f.badge}
                </span>
              )}
              <div class="mb-3">
                <Fragment set:html={f.icon} />
              </div>
              <h3 class="text-base font-semibold text-white mb-2">{f.title}</h3>
              <p class="text-sm text-[#a3a3a3] leading-relaxed">{f.desc}</p>
            </div>
          ))}

          <!-- Regular feature cards -->
          {[
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a3a3a3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
              title: 'Cron run history with output',
              desc: 'Every scheduled command run is recorded with exit code, duration, and output. Know exactly what ran, when, and if it succeeded.',
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a3a3a3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
              title: 'Multi-app dashboard',
              desc: 'One view for all your Laravel apps. See health summaries across your fleet and drill into any app in one click.',
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a3a3a3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`,
              title: 'Slack, PagerDuty & webhooks',
              desc: 'Alerts go where your team works. Plus automatic "resolved" notifications when issues clear — so you know it\'s actually fixed.',
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a3a3a3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
              title: 'REST API + MCP server',
              desc: 'Query cron status from your AI assistant. Ask "Did my invoice job run today?" and get a real answer, not a redirect to a dashboard.',
              badge: 'At launch',
            },
          ].map((f, i) => (
            <div class={`reveal reveal-delay-${i + 2} card p-6`}>
              {f.badge && (
                <span class="inline-block text-xs font-medium px-2 py-0.5 rounded-full mb-3"
                      style="background:rgba(34,197,94,0.08); border:1px solid rgba(34,197,94,0.15); color:#22c55e;">
                  {f.badge}
                </span>
              )}
              <div class="mb-3">
                <Fragment set:html={f.icon} />
              </div>
              <h3 class="text-sm font-semibold text-white mb-1.5">{f.title}</h3>
              <p class="text-sm text-[#a3a3a3] leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ========================================
         HOW IT WORKS
    ======================================== -->
    <section class="py-24 md:py-28">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-14">
          <p class="reveal text-xs font-semibold tracking-[0.15em] uppercase text-[#525252] mb-4">How It Works</p>
          <h2 class="reveal reveal-delay-1 text-3xl md:text-4xl font-bold tracking-tight text-white leading-tight">
            Up and running in minutes
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-8 relative">
          <!-- Connector line (desktop only) -->
          <div class="absolute top-6 left-1/3 w-[calc(33.333%-2rem)] h-px hidden md:block" style="background: linear-gradient(to right, #1c1c1c, #22c55e44, #1c1c1c);"></div>
          <div class="absolute top-6 right-1/3 w-[calc(33.333%-2rem)] h-px hidden md:block" style="background: linear-gradient(to right, #1c1c1c, #22c55e44, #1c1c1c);"></div>

          {[
            {
              step: '01',
              title: 'Install the package',
              desc: 'Add the Crontinel package to your Laravel app with one Composer command. No infrastructure changes needed.',
              code: 'composer require crontinel/laravel',
            },
            {
              step: '02',
              title: 'Connect your app',
              desc: 'Point Crontinel at your Laravel app. It reads queue state, cron history, and worker health directly from Redis and your scheduler.',
              code: null,
            },
            {
              step: '03',
              title: 'Get alerted on failures',
              desc: 'Configure alerts in Slack, email, PagerDuty, or any webhook. Crontinel sends real alerts — not "process is up" pings.',
              code: null,
            },
          ].map((step, i) => (
            <div class={`reveal reveal-delay-${i + 1} text-center`}>
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-full mb-5 font-mono text-sm font-bold relative z-10"
                   style="background:#111; border: 1px solid #22c55e; color:#22c55e; box-shadow: 0 0 20px rgba(34,197,94,0.15);">
                {step.step}
              </div>
              <h3 class="text-base font-semibold text-white mb-2">{step.title}</h3>
              <p class="text-sm text-[#a3a3a3] leading-relaxed mb-4">{step.desc}</p>
              {step.code && (
                <code class="block text-xs text-[#22c55e] font-mono px-3 py-2 rounded"
                      style="background:#080808; border: 1px solid #1c1c1c;">
                  {step.code}
                </code>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ========================================
         DASHBOARD PREVIEW
    ======================================== -->
    <section class="py-24 md:py-28" style="background:#0c0c0c;">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <p class="reveal text-xs font-semibold tracking-[0.15em] uppercase text-[#525252] mb-4">The Dashboard</p>
          <h2 class="reveal reveal-delay-1 text-3xl md:text-4xl font-bold tracking-tight text-white leading-tight">
            See everything at a glance
          </h2>
        </div>

        <!-- Terminal mockup -->
        <div class="reveal reveal-delay-2 rounded-xl overflow-hidden"
             style="border: 1px solid #1c1c1c; box-shadow: 0 40px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(34,197,94,0.05);">
          <!-- Title bar -->
          <div class="flex items-center gap-2 px-4 py-3"
               style="background:#0a0a0a; border-bottom: 1px solid #1c1c1c;">
            <span class="w-3 h-3 rounded-full" style="background:#ef4444;"></span>
            <span class="w-3 h-3 rounded-full" style="background:#f59e0b;"></span>
            <span class="w-3 h-3 rounded-full" style="background:#22c55e;"></span>
            <span class="ml-3 text-xs font-mono" style="color:#525252;">app.crontinel.com/apps/my-laravel-app</span>
          </div>
          <!-- Content -->
          <div class="p-6 font-mono text-sm" style="background:#080808;">
            <!-- Horizon status -->
            <div class="mb-6">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs uppercase tracking-widest" style="color:#525252;">Horizon</span>
                <span class="text-xs" style="color:#22c55e;">● running</span>
              </div>
              <div class="grid grid-cols-3 gap-3">
                {[
                  { label: 'Status', value: 'running', color: '#22c55e' },
                  { label: 'Supervisors', value: '2 active', color: '#fff' },
                  { label: 'Failed / min', value: '0.0', color: '#fff' },
                ].map(s => (
                  <div class="rounded p-3" style="background:#0c0c0c; border: 1px solid #1c1c1c;">
                    <div class="text-xs mb-1" style="color:#525252;">{s.label}</div>
                    <div style={`color:${s.color}; font-weight:500;`}>{s.value}</div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Queue table -->
            <div class="mb-6">
              <div class="text-xs uppercase tracking-widest mb-3" style="color:#525252;">Queues</div>
              <table class="w-full text-xs" style="color:#a3a3a3;">
                <thead>
                  <tr style="color:#525252;">
                    <th class="text-left pb-2">Queue</th>
                    <th class="text-right pb-2">Depth</th>
                    <th class="text-right pb-2">Failed</th>
                    <th class="text-right pb-2">Oldest</th>
                    <th class="text-right pb-2">Health</th>
                  </tr>
                </thead>
                <tbody>
                  <tr style="border-top: 1px solid #1c1c1c;">
                    <td class="py-2">default</td>
                    <td class="text-right">5</td>
                    <td class="text-right">0</td>
                    <td class="text-right">12s</td>
                    <td class="text-right" style="color:#22c55e;">✓ ok</td>
                  </tr>
                  <tr style="border-top: 1px solid #1c1c1c; background:rgba(239,68,68,0.05);">
                    <td class="py-2">emails</td>
                    <td class="text-right" style="color:#ef4444;">1,204</td>
                    <td class="text-right" style="color:#ef4444;">3</td>
                    <td class="text-right" style="color:#ef4444;">8m 32s</td>
                    <td class="text-right" style="color:#ef4444;">✗ alert</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <!-- Crons table -->
            <div>
              <div class="text-xs uppercase tracking-widest mb-3" style="color:#525252;">Scheduled Commands</div>
              <table class="w-full text-xs" style="color:#a3a3a3;">
                <thead>
                  <tr style="color:#525252;">
                    <th class="text-left pb-2">Command</th>
                    <th class="text-right pb-2">Last run</th>
                    <th class="text-right pb-2">Duration</th>
                    <th class="text-right pb-2">Status</th>
                  </tr>
                </thead>
                <tbody>
                  <tr style="border-top: 1px solid #1c1c1c;">
                    <td class="py-2">inspire</td>
                    <td class="text-right">6h ago</td>
                    <td class="text-right">124ms</td>
                    <td class="text-right" style="color:#22c55e;">✓ ok</td>
                  </tr>
                  <tr style="border-top: 1px solid #1c1c1c;">
                    <td class="py-2">send-invoices</td>
                    <td class="text-right">5d ago</td>
                    <td class="text-right">2.1s</td>
                    <td class="text-right" style="color:#22c55e;">✓ ok</td>
                  </tr>
                  <tr style="border-top: 1px solid #1c1c1c; background:rgba(245,158,11,0.04);">
