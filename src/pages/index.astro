  }
  .pricing-card .btn { width: 100%; justify-content: center; }

  @media (max-width: 768px) {
    .pricing { grid-template-columns: 1fr; max-width: 24rem; }
  }

  /* ============================================
     OSS PACKAGES
     ============================================ */
  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .pkg {
    display: flex;
