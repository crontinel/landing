<script>
  const monthly = { pro: '$19', team: '$49', proNote: '', teamNote: '' };
  const yearly  = { pro: '$15', team: '$39', proNote: '$182 billed yearly', teamNote: '$470 billed yearly' };

  const btnM = document.getElementById('hp-toggle-monthly')!;
  const btnY = document.getElementById('hp-toggle-yearly')!;
  const proP = document.getElementById('hp-pro-price')!;
  const teamP = document.getElementById('hp-team-price')!;
  const proN = document.getElementById('hp-pro-note')!;
  const teamN = document.getElementById('hp-team-note')!;

  function setM() {
    proP.textContent = monthly.pro; teamP.textContent = monthly.team;
    proN.textContent = monthly.proNote; teamN.textContent = monthly.teamNote;
    btnM.classList.add('bg-white','text-black'); btnM.classList.remove('text-gray-400','hover:text-white');
    btnY.classList.remove('bg-white','text-black'); btnY.classList.add('text-gray-400','hover:text-white');
  }
  function setY() {
    proP.textContent = yearly.pro; teamP.textContent = yearly.team;
    proN.textContent = yearly.proNote; teamN.textContent = yearly.teamNote;
    btnY.classList.add('bg-white','text-black'); btnY.classList.remove('text-gray-400','hover:text-white');
    btnM.classList.remove('bg-white','text-black'); btnM.classList.add('text-gray-400','hover:text-white');
  }

  btnM.addEventListener('click', setM);
  btnY.addEventListener('click', setY);

  const copyBtn = document.getElementById('copy-install-btn');
  const copyIcon = document.getElementById('copy-icon');
  const checkIcon = document.getElementById('check-icon');
  const installCmd = document.getElementById('install-cmd');

  copyBtn?.addEventListener('click', async () => {
    const text = installCmd?.textContent?.trim() ?? '';
    await navigator.clipboard.writeText(text);
    copyIcon?.classList.add('hidden');
    checkIcon?.classList.remove('hidden');
    setTimeout(() => {
      copyIcon?.classList.remove('hidden');
      checkIcon?.classList.add('hidden');
    }, 1500);
  });
</script>
