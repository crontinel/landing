---
import Base from '../layouts/Base.astro';
---

<Base title="Crontinel — Your cron is lying to you" description="Know when your cron jobs, schedulers, queues, workers, and AI agents stop working — before your users do. Open-source monitoring that generic uptime tools miss.">

