---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Crontinel: Laravel Horizon & Cron Monitoring"
  description="Crontinel monitors Laravel Horizon internals, queue depth, and cron health. Things generic monitors can't see."
>
  <Nav />

  <main>
    <!-- Hero -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-20 pb-16 text-center">
      <div class="inline-flex items-center gap-2 bg-green-500/10 text-green-400 text-xs font-medium px-3 py-1 rounded-full border border-green-500/20 mb-6">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
        </span>
        Laravel-first. More frameworks coming.
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight tracking-tight mb-6">
        Your Laravel Horizon has been<br class="hidden sm:block" />
        <span class="text-red-400">silently broken for 3 days.</span>
      </h1>

      <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10">
        Crontinel monitors Horizon internals, queue depth, and cron health.
        The things generic monitors can't see.
      </p>

      <!-- Email capture -->
      <form
        id="waitlist-form"
        class="flex flex-col sm:flex-row items-center justify-center gap-3 max-w-md mx-auto"
      >
        <input
          type="email"
          id="waitlist-email"
          placeholder="you@yourapp.com"
          required
          class="w-full sm:flex-1 bg-gray-900 border border-gray-700 text-white placeholder-gray-500 px-4 py-3 rounded-lg text-sm focus:outline-none focus:border-green-500 transition-colors"
        />
        <button
          type="submit"
          id="waitlist-btn"
          class="w-full sm:w-auto bg-green-500 hover:bg-green-400 disabled:opacity-50 text-black font-semibold px-5 py-3 rounded-lg transition-colors text-sm whitespace-nowrap"
        >
          Get early access
        </button>
      </form>
      <p id="waitlist-msg" class="mt-3 text-sm hidden"></p>
      <p class="mt-3 text-xs text-gray-600">No credit card. No spam. Unsubscribe anytime.</p>

      <div class="flex items-center justify-center gap-4 mt-6">
        <a
          href="https://github.com/HarunRRayhan/crontinel"
          target="_blank"
          rel="noopener"
          class="text-sm text-gray-500 hover:text-gray-300 transition-colors"
        >
          Self-host for free →
        </a>
        <span class="text-gray-700">·</span>
        <code class="text-gray-500 bg-gray-900 px-2 py-0.5 rounded text-xs">composer require harunrrayhan/crontinel</code>
      </div>

      <script>
        const form = document.getElementById('waitlist-form') as HTMLFormElement;
        const emailInput = document.getElementById('waitlist-email') as HTMLInputElement;
        const btn = document.getElementById('waitlist-btn') as HTMLButtonElement;
        const msg = document.getElementById('waitlist-msg') as HTMLParagraphElement;

        form?.addEventListener('submit', async (e) => {
          e.preventDefault();
          btn.disabled = true;
          btn.textContent = 'Joining...';
          msg.className = 'mt-3 text-sm hidden';

          try {
            const res = await fetch('/api/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email: emailInput.value }),
            });

            const data = await res.json();

            if (res.ok && data.ok) {
              msg.textContent = "You're on the list! We'll email you when Crontinel launches.";
              msg.className = 'mt-3 text-sm text-green-400';
              form.reset();
            } else {
              msg.textContent = data.error ?? 'Something went wrong. Please try again.';
              msg.className = 'mt-3 text-sm text-red-400';
              btn.disabled = false;
              btn.textContent = 'Get early access';
            }
          } catch {
            msg.textContent = 'Network error. Please try again.';
            msg.className = 'mt-3 text-sm text-red-400';
            btn.disabled = false;
            btn.textContent = 'Get early access';
          }
        });
      </script>
    </section>

    <!-- Dashboard preview -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20">
      <div class="rounded-xl border border-gray-800 bg-gray-900 overflow-hidden shadow-2xl">
        <div class="flex items-center gap-1.5 px-4 py-3 border-b border-gray-800 bg-gray-950">
          <span class="w-3 h-3 rounded-full bg-red-500/60"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/60"></span>
          <span class="w-3 h-3 rounded-full bg-green-500/60"></span>
          <span class="text-xs text-gray-600 ml-2">app.crontinel.com/apps/my-laravel-app</span>
        </div>
        <div class="p-6 font-mono text-sm space-y-4">
          <!-- Horizon section -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="text-gray-500 text-xs uppercase tracking-widest">Horizon</span>
              <span class="text-green-400 text-xs">● running</span>
            </div>
            <div class="grid grid-cols-3 gap-3">
              <div class="bg-gray-950 rounded p-3">
                <div class="text-xs text-gray-500 mb-1">Status</div>
                <div class="text-green-400 font-medium">running</div>
              </div>
              <div class="bg-gray-950 rounded p-3">
                <div class="text-xs text-gray-500 mb-1">Supervisors</div>
                <div class="text-white font-medium">2 active</div>
              </div>
              <div class="bg-gray-950 rounded p-3">
                <div class="text-xs text-gray-500 mb-1">Failed / min</div>
                <div class="text-white font-medium">0.0</div>
              </div>
            </div>
          </div>

          <!-- Queues section -->
          <div>
            <div class="text-gray-500 text-xs uppercase tracking-widest mb-2">Queues</div>
            <table class="w-full text-xs">
              <thead>
                <tr class="text-gray-600">
                  <th class="text-left py-1">Queue</th>
                  <th class="text-right py-1">Depth</th>
                  <th class="text-right py-1">Failed</th>
                  <th class="text-right py-1">Oldest</th>
                  <th class="text-right py-1">Health</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-800">
                <tr>
                  <td class="py-1.5 text-gray-300">default</td>
                  <td class="text-right text-gray-300">5</td>
                  <td class="text-right text-gray-300">0</td>
                  <td class="text-right text-gray-300">12s</td>
                  <td class="text-right text-green-400">✓ ok</td>
                </tr>
                <tr class="bg-red-950/30">
                  <td class="py-1.5 text-gray-300">emails</td>
                  <td class="text-right text-red-400">1,204</td>
                  <td class="text-right text-red-400">3</td>
                  <td class="text-right text-red-400">8m 32s</td>
                  <td class="text-right text-red-400">✗ alert</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Crons section -->
          <div>
            <div class="text-gray-500 text-xs uppercase tracking-widest mb-2">Scheduled Commands</div>
            <table class="w-full text-xs">
              <thead>
                <tr class="text-gray-600">
                  <th class="text-left py-1">Command</th>
                  <th class="text-right py-1">Last run</th>
                  <th class="text-right py-1">Duration</th>
                  <th class="text-right py-1">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-800">
                <tr>
                  <td class="py-1.5 text-gray-300">inspire</td>
                  <td class="text-right text-gray-400">6h ago</td>
                  <td class="text-right text-gray-400">124ms</td>
                  <td class="text-right text-green-400">✓ ok</td>
                </tr>
                <tr>
                  <td class="py-1.5 text-gray-300">send-invoices</td>
                  <td class="text-right text-gray-400">5d ago</td>
                  <td class="text-right text-gray-400">2.1s</td>
                  <td class="text-right text-green-400">✓ ok</td>
                </tr>
                <tr class="bg-yellow-950/20">
                  <td class="py-1.5 text-gray-300">cleanup-old-logs</td>
                  <td class="text-right text-gray-400">23h ago</td>
                  <td class="text-right text-gray-400">—</td>
                  <td class="text-right text-yellow-400">⚠ late</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem section -->
    <section class="bg-gray-900/40 border-y border-gray-800">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
        <h2 class="text-2xl sm:text-3xl font-bold text-white text-center mb-4">
          Generic monitors only check if a job pinged back.
        </h2>
        <p class="text-gray-400 text-center max-w-xl mx-auto mb-12">
          Forge Heartbeats tell you a job ran. They don't tell you your Horizon supervisor is paused.
        </p>

        <div class="grid sm:grid-cols-3 gap-6">
          {[
            {
              icon: '🔇',
              title: 'Silent cron failures',
              desc: 'Your send-invoices job has been failing silently for 3 days. The generic monitor shows green because the process started.',
            },
            {
              icon: '📦',
              title: 'Queue backlog accumulation',
              desc: 'The emails queue has 8,000 jobs pending. Nobody knows until customers start complaining.',
            },
            {
              icon: '💀',
              title: 'Horizon supervisor crashes',
              desc: 'A supervisor process died. Horizon shows "running" because one supervisor is still up. Your email queue is dead.',
            },
          ].map((card) => (
            <div class="bg-gray-900 rounded-xl p-6 border border-gray-800">
              <div class="text-3xl mb-3">{card.icon}</div>
              <h3 class="font-semibold text-white mb-2">{card.title}</h3>
              <p class="text-sm text-gray-400 leading-relaxed">{card.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Features grid -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
      <h2 class="text-2xl sm:text-3xl font-bold text-white text-center mb-4">
        Everything you need to sleep at night
      </h2>
      <p class="text-gray-400 text-center max-w-xl mx-auto mb-12">
        Crontinel hooks into app internals, not just HTTP pings.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            title: 'Horizon internals',
            desc: 'Reads Redis directly. Knows which supervisor is down, the failed job rate per minute, and whether Horizon is paused.',
            badge: 'Unique',
          },
          {
            title: 'Queue depth alerts',
            desc: 'Configurable thresholds per queue. Get alerted when depth, failed count, or oldest job age exceeds limits.',
          },
          {
            title: 'Cron run history',
            desc: 'Every scheduled command run is recorded with exit code, duration, and output. Know exactly what ran and when.',
          },
          {
            title: 'Multi-app dashboard',
            desc: 'One view for all your apps. See health summaries and drill into any app in one click.',
          },
          {
            title: 'Slack, PagerDuty & webhooks',
            desc: 'Alerts go where you work. Plus automatic "resolved" notifications when issues clear.',
          },
          {
            title: 'REST API + MCP server',
            desc: 'Query cron status from your AI assistant. Ask Claude Code "did my invoice job run?" and get the answer inline.',
            badge: 'At launch',
          },
        ].map((f) => (
          <div class="bg-gray-900 rounded-xl p-6 border border-gray-800 relative">
            {f.badge && (
              <span class="absolute top-4 right-4 text-xs text-green-400 bg-green-500/10 border border-green-500/20 px-2 py-0.5 rounded-full">
                {f.badge}
              </span>
            )}
            <h3 class="font-semibold text-white mb-2">{f.title}</h3>
            <p class="text-sm text-gray-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Pricing section -->
    <section id="pricing" class="bg-gray-900/40 border-y border-gray-800">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
        <h2 class="text-2xl sm:text-3xl font-bold text-white text-center mb-4">Simple pricing</h2>
        <p class="text-gray-400 text-center mb-12">14-day Pro trial included. No credit card required.</p>

        <div class="grid sm:grid-cols-3 gap-6">
          <!-- Free -->
          <div class="bg-gray-900 rounded-xl p-6 border border-gray-800 flex flex-col">
            <div class="mb-4">
              <div class="text-sm text-gray-500 uppercase tracking-wide mb-1">Free</div>
              <div class="text-3xl font-bold text-white">$0</div>
              <div class="text-sm text-gray-500 mt-1">forever</div>
            </div>
            <ul class="space-y-2 text-sm text-gray-400 flex-1 mb-6">
              <li class="flex gap-2"><span class="text-green-400">✓</span> 1 app</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> 5 monitors per app</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> 7-day history</li>
              <li class="flex gap-2"><span class="text-gray-600">✗</span> Alerts</li>
              <li class="flex gap-2"><span class="text-gray-600">✗</span> API access</li>
            </ul>
            <a href="/#waitlist" class="block text-center border border-gray-700 hover:border-gray-500 text-gray-300 font-medium py-2 rounded-lg transition-colors text-sm">
              Start free
            </a>
          </div>

          <!-- Pro (highlighted) -->
          <div class="bg-gray-900 rounded-xl p-6 border border-green-500/40 flex flex-col relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-green-500 text-black text-xs font-semibold px-3 py-0.5 rounded-full">
              Most popular
            </div>
            <div class="mb-4">
              <div class="text-sm text-gray-500 uppercase tracking-wide mb-1">Pro</div>
              <div class="text-3xl font-bold text-white">$19<span class="text-lg font-normal text-gray-500">/mo</span></div>
              <div class="text-sm text-green-400 mt-1">$182/yr (save 20%)</div>
            </div>
            <ul class="space-y-2 text-sm text-gray-400 flex-1 mb-6">
              <li class="flex gap-2"><span class="text-green-400">✓</span> 5 apps</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> Unlimited monitors</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> 90-day history</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> Slack, email, PagerDuty alerts</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> REST API access</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> Status page (1 per app)</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> 3 team members</li>
            </ul>
            <a href="/#waitlist" class="block text-center bg-green-500 hover:bg-green-400 text-black font-semibold py-2 rounded-lg transition-colors text-sm">
              Start 14-day trial
            </a>
          </div>

          <!-- Team -->
          <div class="bg-gray-900 rounded-xl p-6 border border-gray-800 flex flex-col">
            <div class="mb-4">
              <div class="text-sm text-gray-500 uppercase tracking-wide mb-1">Team</div>
              <div class="text-3xl font-bold text-white">$49<span class="text-lg font-normal text-gray-500">/mo</span></div>
              <div class="text-sm text-green-400 mt-1">$470/yr (save 20%)</div>
            </div>
            <ul class="space-y-2 text-sm text-gray-400 flex-1 mb-6">
              <li class="flex gap-2"><span class="text-green-400">✓</span> Unlimited apps</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> Unlimited monitors</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> 1-year history</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> Unlimited team members</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> Unlimited status pages</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> Custom alert rules</li>
              <li class="flex gap-2"><span class="text-green-400">✓</span> Priority support</li>
            </ul>
            <a href="/#waitlist" class="block text-center border border-gray-700 hover:border-gray-500 text-gray-300 font-medium py-2 rounded-lg transition-colors text-sm">
              Start 14-day trial
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- OSS callout -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 text-center">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-8 max-w-2xl mx-auto">
        <h2 class="text-xl font-bold text-white mb-3">Also free, forever, as an OSS package</h2>
        <p class="text-gray-400 text-sm mb-6">
          The MIT package works standalone: Blade dashboard, CLI check, Slack alerts, full Horizon monitoring.
          No SaaS required. Self-host and own your data.
        </p>
        <code class="block bg-gray-950 text-green-400 text-sm rounded-lg px-4 py-3 mb-6">
          composer require harunrrayhan/crontinel
        </code>
        <a
          href="https://github.com/HarunRRayhan/crontinel"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Base>
