---
import Base from '../layouts/Base.astro';

export const prerender = true;

const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? '';
const canonicalURL = new URL('/', 'https://crontinel.com').toString();
const title = 'Crontinel // See your cron before it screams';
const description = 'Crontinel watches the jobs, queues, workers, models and agents behind your app, so you hear about the failure before your users do.';
---

<!-- JSON-LD -->
<script type="application/ld+json" slot="head" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://crontinel.com/#organization",
      "name": "Crontinel",
      "url": "https://crontinel.com",
      "logo": { "@type": "ImageObject", "url": "https://crontinel.com/favicon.svg" },
      "sameAs": ["https://github.com/crontinel", "https://x.com/CrontinelApp"]
    },
    {
      "@type": "WebSite",
      "@id": "https://crontinel.com/#website",
      "url": "https://crontinel.com",
      "name": "Crontinel",
      "description": "Cron, Scheduler & Background Job Monitoring",
      "publisher": { "@id": "https://crontinel.com/#organization" }
    }
  ]
})} />

<!-- Fonts (index page only) -->
<link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
<link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link slot="head" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<!-- Design system tokens -->
<link slot="head" rel="stylesheet" href="/styles/crontinel-tokens.css" />
<link slot="head" rel="stylesheet" href="/styles/components.css" />

<!-- Page-level utilities -->
<style>
    /* Skip link */
    .skip-to-main {
      position: fixed; top: -100%; left: 0.5rem; z-index: 9999;
      background: var(--accent); color: #000; font-weight: 600;
      padding: 0.5rem 1rem; border-radius: 0 0 0.375rem 0;
      text-decoration: none; transition: top 0.15s ease;
    }
    .skip-to-main:focus { top: 0; }

    /* Hero status caption row */
    .hero-captions {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 18px;
      margin-top: 14px;
      font-size: 12px;
      color: var(--text-3);
    }
    .hero-captions span { display: inline-flex; align-items: center; gap: 7px; }

    /* Problem card icon row */
    .pico {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-mono);
      font-size: 11.5px;
      color: var(--text-3);
    }

    /* Danger text colour */
    .danger { color: var(--danger); }

    /* Prevent horizontal bleed at small widths */
    html, body { max-width: 100%; overflow-x: hidden; }

    /* ── MOBILE FIXES ─────────────────────────────────────────────────
       The design CSS references .db-table in responsive rules, but our
       HTML uses .table. These overrides correct that mismatch and plug
       any remaining mobile overflow gaps.
    ──────────────────────────────────────────────────────────────────── */

    /* Allow pre blocks to scroll rather than force-expand the page */
    pre { max-width: 100%; overflow-x: auto; }
    .step pre { overflow-x: auto; }

    /* At 860 px: ensure .table (our class) also gets overflow-x guard */
    @media (max-width: 860px) {
      .table { max-width: 100%; }
      /* Dashboard: let panel scroll rather than clip table content */
      .db-panel { overflow-x: auto; }
    }

    /* At 640 px (phone): match .db-table rules that components.css sets
       but never applies because our HTML uses .table */
    @media (max-width: 640px) {
      .table th, .table td { padding: 8px 6px; font-size: 11.5px; }
      .table td:nth-child(3), .table th:nth-child(3) { display: none; }
      /* Remove fixed min-height so the dashboard collapses cleanly */
      .db-body { min-height: 0 !important; }
      /* Dashboard KPI strip — ensure 2 cols already applied */
      .kpis { grid-template-columns: repeat(2, 1fr) !important; }
      /* Hero monitor height guard */
      .monitor-graph { height: 160px; }
    }

    /* At 480 px: monitor-head wraps to avoid overflow */
    @media (max-width: 480px) {
      .monitor-head { flex-wrap: wrap; gap: 8px; padding: 12px 14px; }
      .monitor-head .label { font-size: 11px; }
      .monitor-head .stats { font-size: 11px; }
      /* Hero captions: stack to avoid wide inline row */
      .hero-captions { flex-direction: column; gap: 6px; }
      /* db-title wraps on narrow screens */
      .db-title { flex-wrap: wrap; gap: 8px; }
      .db-title h3 { font-size: 18px; }
    }

    /* At 380 px: further tighten anything that could bleed */
    @media (max-width: 380px) {
      .monitor-head .label span:nth-child(3),
      .monitor-head .label span:nth-child(4) { display: none; }
      .hero-trust { font-size: 10px; }
    }

    /* ── SOCIAL PROOF STRIP ─────────────────────────────────────────── */
    .section-muted { background: var(--bg-alt, rgba(255,255,255,0.02)); }
    .proof-strip { display: flex; flex-direction: column; align-items: center; gap: 16px; padding: 8px 0; }
    .proof-label { font-size: 12px; color: var(--text-3); }
    .proof-stats { display: flex; align-items: center; gap: 0; flex-wrap: wrap; justify-content: center; }
    .proof-stat { display: flex; flex-direction: column; align-items: center; gap: 2px; padding: 0 32px; }
    .proof-n { font-size: 20px; font-weight: 700; color: var(--text); font-family: var(--font-mono); }
    .proof-l { font-size: 11px; color: var(--text-3); }
    .proof-div { width: 1px; height: 32px; background: var(--border); }

    /* ── OSS COMPARE TABLE ────────────────────────────────────────── */
    .oss-compare { margin-top: 48px; }
    .oss-compare h3 { text-align: center; margin-bottom: 8px; }
    .oss-compare > p { text-align: center; color: var(--text-2); margin-bottom: 28px; }
    .oss-compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; max-width: 680px; margin: 0 auto; }
    .oss-compare-col { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; }
    .oss-compare-col--saas { border-color: var(--accent); }
    .oss-compare-head { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-3); margin-bottom: 14px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .oss-compare-head .tag { font-size: 10px; padding: 2px 6px; border-radius: 4px; background: var(--bg-2); border: 1px solid var(--border); color: var(--text-2); letter-spacing: 0; text-transform: none; }
    .oss-compare-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
    .oss-compare-list li { font-size: 13px; color: var(--text-2); padding-left: 20px; position: relative; }
    .oss-compare-list li::before { content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: 12px; height: 12px; border-radius: 50%; }
    .oss-compare-list li.yes { color: var(--text); }
    .oss-compare-list li.yes::before { background: var(--ok); }
    .oss-compare-list li.no { color: var(--text-3); }
    .oss-compare-list li.no::before { background: var(--text-3); opacity: 0.4; }

    /* ── OSS CALLOUT ───────────────────────────────────────────────── */
    .oss-callout { display: flex; gap: 20px; align-items: flex-start; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 24px; margin-top: 40px; max-width: 600px; margin-left: auto; margin-right: auto; }
    .oss-callout-icon { flex-shrink: 0; margin-top: 2px; }
    .oss-callout-body { flex: 1; }
    .oss-callout-body h3 { font-size: 16px; font-weight: 600; color: var(--text); margin-bottom: 8px; }
    .oss-callout-body p { font-size: 13px; color: var(--text-2); margin-bottom: 16px; line-height: 1.6; }
    .oss-callout-cmd { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .oss-callout-cmd code { background: var(--bg-2); border: 1px solid var(--border); border-radius: 6px; padding: 6px 12px; font-size: 13px; color: var(--accent); font-family: var(--font-mono); }
    .oss-pkgs { display: flex; flex-wrap: wrap; gap: 8px; }
    .oss-pkgs code { background: var(--bg-2); border: 1px solid var(--border); border-radius: 6px; padding: 6px 12px; font-size: 12px; color: var(--accent); font-family: var(--font-mono); white-space: nowrap; }

    /* ── RESPONSIVE ───────────────────────────────────────────────── */
    @media (max-width: 640px) {
      .oss-compare-grid { grid-template-columns: 1fr; }
      .oss-callout { flex-direction: column; gap: 12px; }
      .proof-stat { padding: 0 16px; }
    }
  </style>
</head>

<Base title={title} description={description} canonical={canonicalURL}>

<!-- ============================== NAV ============================== -->
<nav class="nav" id="nav">
  <div class="container inner">
    <a href="#top" class="brand">
      <img class="mark" src="/favicon.png" alt="Crontinel" aria-hidden="true"/>
      <span>crontinel</span>
    </a>
    <div class="links" id="nav-links">
      <a href="#features">Features</a>
      <a href="#how">How it works</a>
      <a href="#dashboard">Dashboard</a>
      <a href="/vs">Compare</a>
      <a href="#pricing">Pricing</a>
      <a href="https://docs.crontinel.com" target="_blank" rel="noopener">Docs</a>
    </div>
    <div class="right">
      <a class="btn btn-ghost btn-sm nav-github" href="https://github.com/crontinel/crontinel" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 007.86 10.92c.57.1.78-.25.78-.55v-1.94c-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.74.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.71 0-1.26.45-2.29 1.19-3.1-.12-.3-.52-1.48.11-3.08 0 0 .97-.31 3.18 1.18a11 11 0 015.78 0c2.21-1.5 3.18-1.18 3.18-1.18.63 1.6.24 2.78.12 3.08.74.81 1.19 1.84 1.19 3.1 0 4.44-2.7 5.42-5.27 5.7.41.36.78 1.07.78 2.16v3.2c0 .3.2.66.79.55A11.5 11.5 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"/></svg>
        <span>1.2k</span>
      </a>
      <a class="btn btn-primary btn-sm" href="https://app.crontinel.com/register">Start free <span class="arrow-i">&#8599;</span></a>
      <button class="nav-toggle" id="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="nav-links">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<!-- ============================== ANNOUNCEMENT BAR ============================== -->
<div id="thenping-notice" style="background:#111111;border-bottom:1px solid rgba(74,222,128,0.15);padding:10px 16px;text-align:center;font-size:13px;color:#94a3b8;">
  <span style="color:#4ade80;font-weight:600;">thenping.me is no longer maintained</span>
  &mdash; Crontinel is the active Laravel-native alternative.
  <a href="/blog/thenping-me-is-dead" style="color:#4ade80;text-decoration:underline;margin-left:8px;">Read more &rarr;</a>
  <button onclick="localStorage.setItem('thenping-dismissed','1');this.parentElement.style.display='none'" aria-label="Dismiss" style="margin-left:12px;color:#64748b;background:none;border:none;cursor:pointer;font-size:16px;line-height:1;">&times;</button>
</div>
<script>if(localStorage.getItem('thenping-dismissed')){document.getElementById('thenping-notice').style.display='none';}</script>

<!-- ============================== HERO ============================== -->
<main id="main-content">
<header class="hero" id="top">
  <div class="hero-bg" aria-hidden="true">
    <div class="grid"></div>
    <div class="glow"></div>
    <div class="scanline"></div>
  </div>
  <div class="container hero-inner">
    <div class="hero-left">
      <span class="hero-status">
        <span class="ping"></span>
        <span class="mono">all.systems.operational</span>
        <span class="sep">·</span>
        <span class="mono" id="hero-uptime">99.987% last 30d</span>
      </span>

      <h1 class="display h1" id="headline">
        Your cron<br/>
        is <span class="accent">lying</span><br/>
        to you.<span class="cursor"></span>
      </h1>

      <p class="hero-sub" id="sub">
        Crontinel watches the jobs, queues, workers, models and agents behind your app,
        so you hear about the failure <em>before</em> your users do.
      </p>

      <div class="hero-ctas">
        <a class="btn btn-primary" href="https://app.crontinel.com">Start monitoring free <span class="arrow-i">&#8599;</span></a>
        <a class="btn btn-ghost" href="https://github.com/crontinel/crontinel" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 007.86 10.92c.57.1.78-.25.78-.55v-1.94c-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.74.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.71 0-1.26.45-2.29 1.19-3.1-.12-.3-.52-1.48.11-3.08 0 0 .97-.31 3.18 1.18a11 11 0 015.78 0c2.21-1.5 3.18-1.18 3.18-1.18.63 1.6.24 2.78.12 3.08.74.81 1.19 1.84 1.19 3.1 0 4.44-2.7 5.42-5.27 5.7.41.36.78 1.07.78 2.16v3.2c0 .3.2.66.79.55A11.5 11.5 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"/></svg>
          View on GitHub
        </a>
      </div>

      <div class="hero-trust mono">
        <span>node · python · go · php · ruby · rails · cli · dotnet</span>
        <span class="sep">·</span>
        <span>MIT licensed</span>
        <span class="sep">·</span>
        <span>free tier, no card</span>
      </div>
    </div>

    <!-- HEARTBEAT MONITOR -->
    <div class="hero-right">
      <div class="monitor" id="monitor">
        <div class="monitor-head">
          <div class="label">
            <span class="dot"></span>
            <span>live.monitor</span>
            <span class="sep">·</span>
            <span>app.crontinel.com</span>
          </div>
          <div class="stats">
            <span class="stat">jobs<b id="stat-jobs">1,847</b></span>
            <span class="stat">latency<b id="stat-lat">42ms</b></span>
          </div>
        </div>

        <div class="monitor-graph">
          <div class="grid-faint"></div>
          <svg viewBox="0 0 600 220" preserveAspectRatio="none">
            <defs>
              <linearGradient id="g1" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.35"/>
                <stop offset="100%" stop-color="var(--accent)" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <path id="hb-fill" d="" fill="url(#g1)"/>
            <path id="hb-line" d="" fill="none" stroke="var(--accent)" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round"/>
            <circle id="hb-dot" r="4" fill="var(--accent)">
              <animate attributeName="r" values="4;7;4" dur="1.2s" repeatCount="indefinite"/>
            </circle>
          </svg>
        </div>

        <div class="monitor-feed" id="feed">
          <!-- JS populates -->
        </div>
      </div>

      <div class="hero-captions mono">
        <span><span class="status-dot ok"></span>heartbeat · every 60s</span>
        <span><span class="status-dot fail"></span>failure · detected in <b>&lt; 60s</b></span>
        <span><span class="status-dot warn"></span>drift · scheduler out of sync</span>
      </div>
    </div>
  </div>
</header>

<!-- ============================== METRICS ============================== -->
<section class="section section-metrics" id="sec-metrics">
  <div class="container">
    <div class="metrics reveal">
      <div class="metric">
        <div class="n" data-count="62"><span class="val">0</span><span class="unit">s</span></div>
        <div class="l">avg time to detect<br/>a silent cron failure</div>
      </div>
      <div class="metric">
        <div class="n" data-count="14"><span class="val">0</span><span class="unit">%</span></div>
        <div class="l">of production apps<br/>run a silently broken job</div>
      </div>
      <div class="metric">
        <div class="n"><span>2</span><span class="unit"> cmds</span></div>
        <div class="l">to monitor jobs,<br/>queues, workers &amp; agents</div>
      </div>
      <div class="metric">
        <div class="n">$<span class="val" data-count="19">0</span><span class="unit">/mo</span></div>
        <div class="l">starts at, or<br/>self-host for free</div>
      </div>
    </div>
  </div>
</section>

<!-- ============================== PROBLEM ============================== -->
<section class="section" id="sec-problem">
  <div class="container">
    <div class="section-head reveal section-head--split">
      <div class="section-head-copy">
        <span class="eyebrow">The gap</span>
        <h2 class="display h2">Your uptime monitor says <span class="ok-green">green</span>.<br/>Your queue disagrees.</h2>
        <p class="body">
          A URL responding 200 doesn't mean your cron ran. It doesn't mean your workers are draining.
          It doesn't mean your <span class="mono accent">invoices</span> queue isn't 6,000 deep, or that your agent isn't looping on a broken tool call.
          Generic monitors can't tell you any of that.
        </p>
      </div>
      <aside class="section-head-aside">
        <div class="gap-wall" aria-hidden="true">
          <div class="gap-col">
            <div class="gap-col-h"><span class="mono t-mute">uptime.check</span><span class="pill pill-ok">all green</span></div>
            <ul class="gap-list">
              <li><span class="dot ok"></span> <span class="mono">GET /health</span> <span class="t-mute">200</span></li>
              <li><span class="dot ok"></span> <span class="mono">GET /api/v1</span> <span class="t-mute">200</span></li>
              <li><span class="dot ok"></span> <span class="mono">GET /login</span> <span class="t-mute">200</span></li>
              <li><span class="dot ok"></span> <span class="mono">TLS</span> <span class="t-mute">valid</span></li>
            </ul>
          </div>
          <div class="gap-divider"><span>vs</span></div>
          <div class="gap-col gap-col--truth">
            <div class="gap-col-h"><span class="mono t-mute">crontinel</span><span class="pill pill-bad">3 silent failures</span></div>
            <ul class="gap-list">
              <li><span class="dot fail"></span> <span class="mono">schedule:run</span> <span class="t-mute">17h late</span></li>
              <li><span class="dot fail"></span> <span class="mono">agent.run.874</span> <span class="t-mute">42m loop</span></li>
              <li><span class="dot warn"></span> <span class="mono">queue:invoices</span> <span class="t-mute">6.2k deep</span></li>
              <li><span class="dot ok"></span> <span class="mono">worker.main</span> <span class="t-mute">ok</span></li>
            </ul>
          </div>
        </div>
      </aside>
    </div>
    <div class="problem-grid">
      <article class="card problem reveal">
        <div class="pico"><span class="dot warn"></span> <span class="mono">scheduled.task</span></div>
        <h3>Scheduler stops. Site stays up.</h3>
        <p class="body-sm">A deploy clobbers your cron entry. The app responds 200. No one fires the scheduler. Your nightly emails stop.</p>
        <pre class="mock"><span class="good">GET /health         200 ok</span>
<span class="bad">schedule:run        · 17h ago</span></pre>
      </article>
      <article class="card problem reveal">
        <div class="pico"><span class="dot fail"></span> <span class="mono">agent.loop</span></div>
        <h3>The agent loops. The bill climbs.</h3>
        <p class="body-sm">A model retry storm or a tool-call loop runs for 40 minutes. The endpoint returns 200 for every request. You find out from billing.</p>
        <pre class="mock"><span class="good">api.status          200 ok</span>
<span class="bad">agent.run.874       42m · 318 tool calls</span></pre>
      </article>
      <article class="card problem reveal">
        <div class="pico"><span class="dot fail"></span> <span class="mono">worker.crash</span></div>
        <h3>Worker crashes. Queue is dead.</h3>
        <p class="body-sm">A worker process died. Your queue manager shows "running" because one worker is still up. Your billing queue is dead. No errors. No alerts. Just silence.</p>
        <pre class="mock"><span class="good">queue.manager       running</span>
<span class="bad">worker.emails       · crashed</span></pre>
      </article>
    </div>
  </div>
</section>

<!-- ============================== FEATURES BENTO ============================== -->
<section class="section" id="features">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Everything uptime tools miss</span>
      <h2 class="display h2">Paranoid monitoring,<br/>without the instrumentation.</h2>
      <p class="body">One SDK hooks into your scheduler, queue driver and agent runner. It watches job runs, queue depth, worker state, model latency and agent tool calls, end to end. No endpoint pings. No per-task wrapping. No missed instrumentation.</p>
    </div>

    <div class="bento">
      <article class="card b b-lg b-viz reveal">
        <div>
          <span class="b-eyebrow">Workers &amp; supervisors</span>
          <h3 class="b-title">See the worker, not just the URL.</h3>
          <p class="b-desc">Per-worker status, paused detection, queue sparklines, failed job rate. Horizon, Sidekiq, Celery, BullMQ, RQ, Temporal. The moment one blinks, you know.</p>
        </div>
        <div class="horizon-grid" id="workers-grid">
          <!-- JS populates cells -->
        </div>
      </article>

      <article class="card b b-md b-viz reveal">
        <div>
          <span class="b-eyebrow">Heartbeat</span>
          <h3 class="b-title">60-second detection.</h3>
          <p class="b-desc">Every scheduled task registers a run attempt, exit code, and duration. Missed runs trip an alert before the next cron tick.</p>
        </div>
        <div class="viz-ping">
          <span>pulse</span>
          <div class="wave"></div>
          <span class="accent mono">60s</span>
        </div>
      </article>

      <article class="card b b-sm b-text reveal">
        <span class="b-eyebrow">Zero wrap</span>
        <h3 class="b-title">No per-task instrumentation.</h3>
        <p class="b-desc">Hooks into your framework's events, not your code.</p>
      </article>

      <article class="card b b-sm b-text reveal">
        <span class="b-eyebrow">Self-hosted</span>
        <h3 class="b-title">Works offline. MIT.</h3>
        <p class="b-desc">OSS first. Local dashboard, CLI, no SaaS needed.</p>
      </article>

      <article class="card b b-md b-viz reveal">
        <div>
          <span class="b-eyebrow">Alerts</span>
