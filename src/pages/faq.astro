<Base
  title="FAQ — Crontinel"
  description="Common questions about Crontinel: what it monitors, how it compares to alternatives, pricing, self-hosting, and getting started."
>
  <Nav />

  <main class="max-w-2xl mx-auto px-4 sm:px-6 py-16">
    <div class="mb-12">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">FAQ</h1>
      <p class="text-gray-400">
        Common questions about installation, plans, data privacy, and how Crontinel works.
      </p>
    </div>

    <div class="space-y-10">
      {faqs.map((item) => (
        <div class="border-b border-gray-800 pb-10">
          <h2 class="text-lg font-semibold text-white mb-3">{item.q}</h2>
          <div class="text-sm text-gray-400 leading-relaxed" set:html={item.a} />
        </div>
      ))}
    </div>

    <div class="mt-16 border border-gray-800 rounded-lg p-6 text-center">
      <p class="text-sm text-gray-400 mb-4">Something not covered here?</p>
      <a
        href="https://discord.com/invite/clawd"
        class="inline-block text-sm text-green-400 hover:text-green-300 transition-colors"
      >
        Ask in the Discord community &rarr;
      </a>
    </div>
  </main>

  <Footer />
</Base>
