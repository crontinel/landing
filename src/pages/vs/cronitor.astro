---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base
  title="Crontinel vs Cronitor: Laravel Cron Monitoring Comparison"
  description="Cronitor tells you a job ran. Crontinel tells you your Horizon supervisor is paused. Here's what that difference means for Laravel apps."
>
  <Nav />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-16">

    <div class="text-center mb-14">
      <div class="inline-block text-xs font-semibold text-gray-400 bg-gray-800 border border-gray-700 px-3 py-1 rounded-full mb-4">
        Crontinel vs Cronitor
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Cronitor checks if your job pinged back.<br class="hidden sm:block" /> Crontinel checks if it should have run.
      </h1>
      <p class="text-gray-400 max-w-xl mx-auto">
        Cronitor wraps cron jobs in ping-in/ping-out monitoring. It works, until your Horizon supervisor silently pauses and no jobs run at all. Cronitor sees nothing. Crontinel does.
      </p>
    </div>

    <div class="space-y-8 mb-16">

      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-white mb-2">The problem Cronitor misses</h2>
        <p class="text-gray-400 mb-4">
          Cronitor watches for a ping from your job. If your job doesn't run because Horizon is paused, Cronitor waits for a ping that never comes, and alerts after a grace period, not immediately. By then, jobs have been silently dropped for minutes.
        </p>
        <div class="bg-gray-950 rounded-lg p-4 font-mono text-xs text-gray-400 space-y-1">
          <div><span class="text-red-400">✗</span> Horizon supervisor: paused (Cronitor doesn't know)</div>
          <div><span class="text-red-400">✗</span> Queue depth: 847 jobs backed up (Cronitor doesn't know)</div>
          <div><span class="text-yellow-400">⏳</span> Cronitor: "Waiting for ping from send-invoices... (grace period: 5 min)"</div>
        </div>
      </div>

      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-white mb-2">What Crontinel sees instead</h2>
        <p class="text-gray-400 mb-4">
          Crontinel reads Horizon's Redis keys directly. No pings required. The moment a supervisor pauses, Crontinel knows and fires an alert immediately.
        </p>
        <div class="bg-gray-950 rounded-lg p-4 font-mono text-xs space-y-1">
          <div><span class="text-yellow-400">⚠</span> <span class="text-yellow-400">Horizon supervisor "default" paused 2m ago</span></div>
          <div><span class="text-red-400">✗</span> Queue "invoices": depth 847, oldest job 8m</div>
          <div><span class="text-green-400">✓</span> Alert fired: Slack #alerts</div>
        </div>
      </div>

    </div>

    <div class="overflow-x-auto mb-16">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-800 text-left">
            <th class="pb-3 text-gray-400 font-medium">Capability</th>
            <th class="pb-3 text-gray-400 font-medium text-center">Crontinel</th>
            <th class="pb-3 text-gray-400 font-medium text-center">Cronitor</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800/50">
          {[
            ['Horizon supervisor status (per supervisor)', true, false],
            ['Horizon paused detection', true, false],
            ['Failed jobs per minute', true, false],
            ['Queue depth monitoring', true, false],
            ['Oldest job age alert', true, false],
            ['Cron run history (exit code + duration)', true, true],
            ['Dead-man ping monitoring', false, true],
            ['Multi-project monitoring', true, true],
            ['Slack alerts', true, true],
            ['Email alerts', true, true],
            ['Open source / self-hostable', true, false],
            ['No code wrapping needed', true, false],
          ].map(([cap, ours, theirs]) => (
            <tr>
              <td class="py-3 text-gray-300">{cap}</td>
              <td class="py-3 text-center">{ours ? <span class="text-green-400">✓</span> : <span class="text-red-400">✗</span>}</td>
              <td class="py-3 text-center">{theirs ? <span class="text-green-400">✓</span> : <span class="text-red-400">✗</span>}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="bg-gray-900 border border-green-500/20 rounded-xl p-8 text-center">
      <h2 class="text-xl font-bold text-white mb-2">Try Crontinel free</h2>
      <p class="text-gray-400 mb-6">
        Install the open-source package in two commands. No account needed to start.
      </p>
      <div class="bg-gray-950 rounded-lg p-4 font-mono text-sm text-green-400 text-left max-w-sm mx-auto mb-6">
        <div>composer require crontinel/laravel</div>
        <div>php artisan crontinel:install</div>
      </div>
      <a
        href="/#waitlist"
        class="inline-block bg-green-500 hover:bg-green-400 text-black font-semibold px-6 py-2.5 rounded transition-colors"
      >
        Start free
      </a>
    </div>

  </main>

  <Footer />
</Base>
