---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const comparisons = [
  {
    name: 'Datadog',
    slug: 'crontinel-vs-datadog',
    tagline: 'Full observability platform. Strong, but broader than most teams need.',
    verdict: 'Best when you need APM, logs, infrastructure, and synthetic tests.',
  },
  {
    name: 'Better Stack',
    slug: 'crontinel-vs-better-stack',
    tagline: 'Uptime plus incident workflows, status pages, and logs.',
    verdict: 'Best when you want one vendor for monitoring and incident response.',
  },
  {
    name: 'UptimeRobot',
    slug: 'crontinel-vs-uptimerobot',
    tagline: 'Popular uptime monitor for simple external checks.',
    verdict: 'Best when you only need external uptime checks.',
  },
  {
    name: 'Pingdom',
    slug: 'crontinel-vs-pingdom',
    tagline: 'Classic uptime and website performance monitoring.',
    verdict: 'Best when you want a classic uptime tool with transaction checks.',
  },
  {
    name: 'Alternatives',
    slug: 'crontinel-alternatives',
    tagline: 'Shortlist other tools by use case, team size, and budget.',
    verdict: 'Best when you want to compare the broader market quickly.',
  },
];
---

<script type="application/ld+json" slot="head">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://crontinel.com" },
    { "@type": "ListItem", "position": 2, "name": "Comparisons", "item": "https://crontinel.com/vs/" }
  ]
}
</script>

<Base
  title="Crontinel Competitors and Comparisons"
  description="Compare Crontinel with Datadog, Better Stack, UptimeRobot, Pingdom, and other monitoring tools."
>
  <Nav />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-16" id="main-content">
    <div class="text-center mb-14">
      <div class="inline-block text-xs font-semibold text-gray-400 bg-gray-800 border border-gray-700 px-3 py-1 rounded-full mb-4">
        Comparison hub
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Crontinel Competitors and Comparisons
      </h1>
      <p class="text-gray-400 max-w-xl mx-auto">
        Compare Crontinel with the most common monitoring tools, alternatives, and use case pages so you can pick the right fit fast.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-4">
      {comparisons.map((c) => (
        <a
          href={`/vs/${c.slug}/`}
          class="group block bg-gray-900 hover:bg-gray-800 border border-gray-800 hover:border-gray-700 rounded-xl p-6 transition-colors"
        >
          <div class="flex items-start justify-between mb-3">
            <h2 class="text-lg font-semibold text-white">
              Crontinel vs {c.name}
            </h2>
            <span class="text-gray-600 group-hover:text-gray-400 transition-colors text-lg">→</span>
          </div>
          <p class="text-sm text-gray-400 mb-2">{c.tagline}</p>
          <p class="text-sm text-yellow-400/80">{c.verdict}</p>
        </a>
      ))}
    </div>

    <div class="mt-16 bg-gray-900 border border-gray-800 rounded-xl p-8">
      <h2 class="text-xl font-bold text-white mb-6">The core difference</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-800 text-left">
              <th class="pb-3 text-gray-400 font-medium w-1/3">Capability</th>
              <th class="pb-3 text-gray-400 font-medium text-center">Crontinel</th>
              <th class="pb-3 text-gray-400 font-medium text-center">Generalist tools</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800/50">
            {[
              ['Knows a job is late or missed', true, false],
              ['Tracks cron schedule and duration', true, false],
              ['Covers external uptime checks', true, true],
              ['Requires heavy platform setup', false, true],
              ['Works well for small teams', true, 'sometimes'],
              ['Uses a narrow, focused workflow', true, false],
            ].map(([cap, ours, theirs]) => (
              <tr>
                <td class="py-3 text-gray-300">{cap}</td>
                <td class="py-3 text-center">
                  <span class="text-green-400 font-semibold">✓</span>
                </td>
                <td class="py-3 text-center">
                  {theirs === true
                    ? <span class="text-green-400">✓</span>
                    : theirs === 'sometimes'
                    ? <span class="text-yellow-400 text-xs">some</span>
                    : <span class="text-red-400">✗</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <Footer />
</Base>
