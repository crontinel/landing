---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const comparisons = [
  {
    name: 'Cronitor',
    slug: 'cronitor',
    tagline: 'Generic ping monitor. No Laravel awareness.',
    verdict: 'Misses Horizon failures entirely.',
  },
  {
    name: 'Healthchecks.io',
    slug: 'healthchecksio',
    tagline: 'Dead-simple dead-man switch. Nothing more.',
    verdict: 'Can\'t see queue depth or failed jobs.',
  },
  {
    name: 'Better Stack',
    slug: 'better-stack',
    tagline: 'Uptime and log aggregation. Not Laravel-specific.',
    verdict: 'Won\'t catch a paused Horizon supervisor.',
  },
  {
    name: 'Laravel Telescope',
    slug: 'telescope',
    tagline: 'Great for debugging. Not for monitoring.',
    verdict: 'No alerting, no thresholds, no production visibility.',
  },
  {
    name: 'Datadog',
    slug: 'datadog',
    tagline: 'Full observability platform. Requires DIY setup for queues.',
    verdict: 'Queue monitoring needs custom metrics and days of config.',
  },
  {
    name: 'UptimeRobot',
    slug: 'crontinel-vs-uptimerobot',
    tagline: 'HTTP uptime monitoring. No background job visibility.',
    verdict: 'Your site returns 200 while 14k jobs are stuck.',
  },
  {
    name: 'Forge Heartbeats',
    slug: 'crontinel-vs-forge-heartbeats',
    tagline: 'Ping-based cron check. No queue or Horizon monitoring.',
    verdict: 'Knows the job ran. Not whether it succeeded.',
  },
];
---

<script type="application/ld+json" slot="head">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://crontinel.com" },
    { "@type": "ListItem", "position": 2, "name": "Comparisons", "item": "https://crontinel.com/vs/" }
  ]
}
</script>

<Base
  title="Crontinel vs Alternatives  |  Laravel Monitoring Comparison"
  description="How Crontinel compares to Cronitor, Healthchecks.io, Better Stack, Telescope, Datadog, UptimeRobot, and Forge Heartbeats for Laravel queue and cron monitoring."
>
  <Nav />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-16" id="main-content">
    <div class="text-center mb-14">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Crontinel vs the alternatives
      </h1>
      <p class="text-gray-400 max-w-xl mx-auto">
        Generic monitors watch for HTTP pings. Crontinel reads app internals: Horizon Redis keys, queue tables, scheduler events. That's a different class of tool.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-4">
      {comparisons.map((c) => (
        <a
          href={`/vs/${c.slug}`}
          class="group block bg-gray-900 hover:bg-gray-800 border border-gray-800 hover:border-gray-700 rounded-xl p-6 transition-colors"
        >
          <div class="flex items-start justify-between mb-3">
            <h2 class="text-lg font-semibold text-white">
              Crontinel vs {c.name}
            </h2>
            <span class="text-gray-600 group-hover:text-gray-400 transition-colors text-lg">→</span>
          </div>
          <p class="text-sm text-gray-400 mb-2">{c.tagline}</p>
          <p class="text-sm text-yellow-400/80">{c.verdict}</p>
        </a>
      ))}
    </div>

    <div class="mt-16 bg-gray-900 border border-gray-800 rounded-xl p-8">
      <h2 class="text-xl font-bold text-white mb-6">The core difference</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-800 text-left">
              <th class="pb-3 text-gray-400 font-medium w-1/3">Capability</th>
              <th class="pb-3 text-gray-400 font-medium text-center">Crontinel</th>
              <th class="pb-3 text-gray-400 font-medium text-center">Others</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800/50">
            {[
              ['Knows Horizon is paused (not just stopped)', true, false],
              ['Per-supervisor status', true, false],
              ['Queue depth per queue', true, false],
              ['Oldest job age', true, false],
              ['Cron run history (exit code + duration)', true, false],
              ['Auto-records runs (no wrapping needed)', true, false],
              ['Slack + email alerts', true, 'some'],
              ['Works without outbound HTTP from your app', true, false],
              ['Open source / self-hostable', true, false],
            ].map(([cap, ours, theirs]) => (
              <tr>
                <td class="py-3 text-gray-300">{cap}</td>
                <td class="py-3 text-center">
                  <span class="text-green-400 font-semibold">✓</span>
                </td>
                <td class="py-3 text-center">
                  {theirs === true
                    ? <span class="text-green-400">✓</span>
                    : theirs === 'some'
                    ? <span class="text-yellow-400 text-xs">some</span>
                    : <span class="text-red-400">✗</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <Footer />
</Base>
