---
import '../styles/global.css';

const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? '';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Know when your cron jobs, schedulers, and background jobs stop working, before your customers do. Health monitoring that generic uptime tools miss.',
  canonical,
  ogImage = '/og-default.png',
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en" class="bg-gray-950 text-gray-100">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Crontinel" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@HarunRRayhan" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- JSON-LD: Organization + WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://crontinel.com/#organization",
          "name": "Crontinel",
          "url": "https://crontinel.com",
          "logo": {
            "@type": "ImageObject",
            "url": "https://crontinel.com/favicon.svg"
          },
          "sameAs": [
            "https://github.com/crontinel",
            "https://x.com/HarunRRayhan"
          ]
        },
        {
          "@type": "WebSite",
          "@id": "https://crontinel.com/#website",
          "url": "https://crontinel.com",
          "name": "Crontinel",
          "description": "Cron, Scheduler & Background Job Monitoring",
          "publisher": { "@id": "https://crontinel.com/#organization" }
        }
      ]
    })} />

  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <!-- Skip to main content for screen readers -->
    <a href="#main-content" class="skip-to-main">Skip to main content</a>
    <slot />

    <!-- Cookie consent banner -->
    <div id="cookie-banner" class="fixed bottom-0 inset-x-0 z-50 bg-gray-900 border-t border-gray-800 p-4 hidden">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-start sm:items-center gap-4 justify-between">
        <p class="text-sm text-gray-300">
          We use cookies to understand how visitors use our site.
          <a href="/legal/privacy" class="underline text-gray-200 hover:text-white">Privacy Policy</a>
        </p>
        <div class="flex gap-3 shrink-0">
          <button id="cookie-decline" class="text-sm text-gray-400 hover:text-gray-200 px-3 py-1.5">Decline</button>
          <button id="cookie-accept" class="text-sm bg-green-500 hover:bg-green-400 text-black font-medium px-4 py-1.5 rounded">Accept</button>
        </div>
      </div>
    </div>

    <script is:inline define:vars={{ gaId }}>
      (function() {
        var consent = localStorage.getItem('cookie_consent');
        if (!consent) {
          document.getElementById('cookie-banner').classList.remove('hidden');
        }

        function loadGA() {
          if (!gaId || document.getElementById('ga-script')) return;
          var s = document.createElement('script');
          s.id = 'ga-script';
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
          document.head.appendChild(s);
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        }

        if (localStorage.getItem('cookie_consent') === 'accepted') loadGA();

        document.getElementById('cookie-accept')?.addEventListener('click', function() {
          localStorage.setItem('cookie_consent', 'accepted');
          document.getElementById('cookie-banner').classList.add('hidden');
          loadGA();
        });

        document.getElementById('cookie-decline')?.addEventListener('click', function() {
          localStorage.setItem('cookie_consent', 'declined');
          document.getElementById('cookie-banner').classList.add('hidden');
        });
      })();
    </script>
  </body>
</html>
