---
const navLinks = [
  { href: '/features', label: 'Features' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: 'https://docs.crontinel.com', label: 'Docs', external: true },
];
---

<header id="site-nav" class="sticky top-0 z-40 transition-all duration-300"
        style="border-bottom: 1px solid transparent;">
  <nav aria-label="Main navigation" class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-semibold text-white text-sm">
      <img src="/logo.png" alt="Crontinel" width="22" height="22" class="shrink-0" />
      <span>Crontinel</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm transition-colors"
          style="color:#a3a3a3;"
          {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
          onmouseover="this.style.color='#fff'"
          onmouseout="this.style.color='#a3a3a3'"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Desktop CTA -->
    <div class="hidden md:flex items-center gap-3">
      <a href="https://app.crontinel.com/login"
         class="text-sm transition-colors"
         style="color:#a3a3a3;"
         onmouseover="this.style.color='#fff'"
         onmouseout="this.style.color='#a3a3a3'">
        Sign in
      </a>
      <a href="https://app.crontinel.com/register"
         class="text-sm font-medium px-4 py-1.5 rounded-lg transition-all duration-200"
         style="background:#22c55e; color:#000;"
         onmouseover="this.style.background='#16a34a'"
         onmouseout="this.style.background='#22c55e'">
        Get started
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 transition-colors"
      style="color:#a3a3a3;"
      aria-label="Toggle mobile menu"
      aria-expanded="false"
      onmouseover="this.style.color='#fff'"
      onmouseout="this.style.color='#a3a3a3'"
    >
      <svg id="hamburger-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg id="close-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t px-4 py-4 space-y-1"
    style="background:#000; border-color:#1c1c1c;"
  >
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="block text-sm py-2.5 transition-colors"
        style="color:#a3a3a3;"
        {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
        onmouseover="this.style.color='#fff'"
        onmouseout="this.style.color='#a3a3a3'"
      >
        {link.label}
      </a>
    ))}
    <div class="flex items-center gap-3 pt-3" style="border-top: 1px solid #1c1c1c;">
      <a href="https://app.crontinel.com/login"
         class="flex-1 text-center text-sm py-2 rounded-lg transition-colors border"
         style="border-color:#2a2a2a; color:#a3a3a3;">
        Sign in
      </a>
      <a href="https://app.crontinel.com/register"
         class="flex-1 text-center text-sm font-medium py-2 rounded-lg transition-all duration-200"
         style="background:#22c55e; color:#000;">
        Get started
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const close = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    hamburger?.classList.toggle('hidden', !isOpen);
    close?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
