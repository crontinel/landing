---
const navLinks = [
  { href: '/features', label: 'Features' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/blog', label: 'Blog' },
  { href: 'https://docs.crontinel.com', label: 'Docs', external: true },
];
---

<header class="sticky top-0 z-40 border-b border-gray-800/60 bg-gray-950/90 backdrop-blur">
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">
    <a href="/" class="flex items-center gap-2 font-semibold text-white">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="10" stroke="#4ade80" stroke-width="2"/>
        <path d="M11 6v5.5l3 3" stroke="#4ade80" stroke-width="2" stroke-linecap="round"/>
      </svg>
      Crontinel
    </a>

    <div class="hidden md:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-gray-400 hover:text-white transition-colors"
          {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a href="https://app.crontinel.com/login" class="hidden sm:block text-sm text-gray-400 hover:text-white transition-colors">
        Sign in
      </a>
      <a href="https://app.crontinel.com/register" class="text-sm bg-green-500 hover:bg-green-400 text-black font-medium px-4 py-1.5 rounded transition-colors">
        Start free
      </a>
    </div>
  </nav>
</header>
