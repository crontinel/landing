---
const year = new Date().getFullYear();

const footerLinks = {
  Product: [
    { href: '/features', label: 'Features' },
    { href: '/pricing', label: 'Pricing' },
    { href: '/changelog', label: 'Changelog' },
    { href: '/lifetime-deal', label: 'Lifetime Deal' },
    { href: 'https://status.crontinel.com', label: 'Status', external: true },
  ],
  Developers: [
    { href: 'https://docs.crontinel.com', label: 'Documentation', external: true },
    { href: 'https://docs.crontinel.com/introduction', label: 'Quick Start', external: true },
    { href: '/blog', label: 'Blog' },
    { href: 'https://github.com/crontinel/crontinel', label: 'GitHub', external: true },
    { href: 'https://github.com/crontinel/crontinel/issues', label: 'Issues', external: true },
  ],
  Company: [
    { href: '/about', label: 'About' },
    { href: '/faq', label: 'FAQ' },
    { href: '/security', label: 'Security' },
  ],
  Legal: [
    { href: '/legal/privacy', label: 'Privacy Policy' },
    { href: '/legal/terms', label: 'Terms of Service' },
    { href: '/legal/cookies', label: 'Cookie Policy' },
  ],
};
---

<footer style="border-top: 1px solid #1c1c1c;">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 mb-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 font-semibold text-white text-sm mb-3">
          <img src="/favicon.svg" alt="Crontinel" width="22" height="22" class="shrink-0" />
          Crontinel
        </a>
        <p class="text-xs leading-relaxed" style="color:#525252;">
          Cron, scheduler & background job monitoring for Laravel applications.
        </p>
        <p class="text-xs mt-2" style="color:#525252;">
          Built by <a href="https://github.com/HarunRRayhan" class="hover:text-[#a3a3a3] transition-colors" style="color:#a3a3a3;">Harun R Rayhan</a>
        </p>
      </div>

      <!-- Link columns -->
      {Object.entries(footerLinks).map(([group, links]) => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest mb-3" style="color:#525252;">{group}</h3>
          <ul class="space-y-2">
            {links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm transition-colors"
                  style="color:#a3a3a3;"
                  {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
                  onmouseover="this.style.color='#fff'"
                  onmouseout="this.style.color='#a3a3a3'"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-6"
         style="border-top: 1px solid #1c1c1c;">
      <p class="text-xs" style="color:#525252;">&copy; {year} Crontinel. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="https://github.com/crontinel" target="_blank" rel="noopener"
           class="transition-colors" style="color:#525252;"
           onmouseover="this.style.color='#a3a3a3'"
           onmouseout="this.style.color='#525252'"
           aria-label="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://x.com/crontinel" target="_blank" rel="noopener"
           class="transition-colors" style="color:#525252;"
           onmouseover="this.style.color='#a3a3a3'"
           onmouseout="this.style.color='#525252'"
           aria-label="X (Twitter)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
