---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-800 mt-auto">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <div>
        <a href="/" class="flex items-center gap-2 font-semibold text-white mb-1">
          <img src="/logo-dark.png" alt="Crontinel" width="18" height="18" class="shrink-0" />
          <span>Crontinel</span>
        </a>
        <p class="text-sm text-gray-400">Built by <a href="https://github.com/HarunRRayhan" class="hover:text-gray-300">Harun R Rayhan</a></p>
      </div>

      <nav aria-label="Footer navigation" class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-gray-400">
        <a href="/features" class="hover:text-gray-300">Features</a>
        <a href="/pricing" class="hover:text-gray-300">Pricing</a>
        <a href="/about" class="hover:text-gray-300">About</a>
        <a href="https://docs.crontinel.com" class="hover:text-gray-300" target="_blank" rel="noopener">Docs</a>
        <a href="/lifetime-deal" class="hover:text-gray-300">Lifetime Deal</a>
        <a href="/faq" class="hover:text-gray-300">FAQ</a>
        <a href="/changelog" class="hover:text-gray-300">Changelog</a>
        <a href="https://github.com/crontinel/crontinel" class="hover:text-gray-300" target="_blank" rel="noopener">GitHub</a>
        <a href="https://status.crontinel.com" class="hover:text-gray-300" target="_blank" rel="noopener">Status</a>
        <a href="/security" class="hover:text-gray-300">Security</a>
        <a href="/legal/cookies" class="hover:text-gray-300">Cookies</a>
        <a href="/legal/privacy" class="hover:text-gray-300">Privacy</a>
        <a href="/legal/terms" class="hover:text-gray-300">Terms</a>
      </nav>
    </div>
    <p class="mt-8 text-xs text-gray-600">&copy; {year} Crontinel. All rights reserved.</p>
  </div>
</footer>
