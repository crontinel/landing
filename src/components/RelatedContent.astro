---
export interface RelatedItem {
  href: string;
  title: string;
  description?: string;
  collection: 'blog' | 'use-cases' | 'vs' | 'integrations';
}

interface Props {
  heading?: string;
  items?: RelatedItem[];
}

const { heading = 'See also', items = [] } = Astro.props as Props;
const visibleItems = items.filter(Boolean);
---

{visibleItems.length > 0 && (
  <section class="mt-16 border-t border-slate-800 pt-10">
    <h2 class="text-2xl font-bold text-white mb-6">{heading}</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {visibleItems.map((item) => (
        <a
          href={item.href}
          class="block rounded-xl border border-slate-800 bg-slate-900/60 p-5 transition hover:border-green-500/40 hover:bg-slate-900"
        >
          <div class="text-xs uppercase tracking-[0.2em] text-slate-500 mb-2">{item.collection.replace('-', ' ')}</div>
          <div class="text-lg font-semibold text-white mb-2 leading-snug">{item.title}</div>
          {item.description && <p class="text-sm text-slate-400 leading-relaxed">{item.description}</p>}
        </a>
      ))}
    </div>
  </section>
)}
