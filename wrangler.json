{
	"name": "crontinel-landing",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
		"include": [
			"_astro/**/*.css",
			"_astro/**/*.js",
			"favicon.ico",
			"favicon.png",
			"favicon.svg",
			"robots.txt",
			"og-default.png",
			"og-default.svg",
			"logo-dark.png",
			"logo-light.png",
			"logo-harun.jpg"
		]
	},
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true
}
