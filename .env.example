# ---------------------------------------------------------------
# Crontinel Landing Page - Environment Variables
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------------

# Google Analytics 4 Measurement ID
# Get from: Google Analytics -> Admin -> Data Streams -> your stream
PUBLIC_GA_MEASUREMENT_ID=G-KJDPL4R7LZ

# Bing Webmaster Tools verification code
# Get from: Bing Webmaster Tools -> Add site -> Verify using HTML meta tag
PUBLIC_BING_VERIFICATION_CODE=F5CFE3E385F65BC74C13B13CE18388F7

# Cloudflare Pages deployment (used by GitHub Actions - set as repo secrets, not here)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Anthropic API key for pSEO page generation (scripts/generate-pseo.mjs)
# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-api03-...
